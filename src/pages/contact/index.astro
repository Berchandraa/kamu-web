---
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';

const demo =
  'https://images.unsplash.com/photo-1540574163026-643ea20ade25?q=80&w=1600&auto=format&fit=crop';
---

<Base
  title="Contact"
  description="Contact KAMU Concepts, interior design studio in Umalas, Bali."
>
  <header class="page-head">
    <p class="label page-eyebrow" data-reveal>
      <span class="duo"><span>Contact</span><span class="duo-sub">Umalas, Bali</span></span>
    </p>
    <h1 class="page-title" data-reveal="line">Contact</h1>
    <p class="page-intro" data-reveal data-reveal-delay="0.15">
      Studio address, direct contacts and social channels.
    </p>
  </header>

  <section class="ct grid-12" id="studio-contact">
    <div class="ct-side">
      <div data-reveal="media">
        <Placeholder
          name="contact-01.jpg"
          ratio="3x4"
          demo={demo}
          alt="The KAMU studio in Umalas"
          parallax
        />
      </div>

      <div class="ct-rows" data-reveal data-reveal-delay="0.15">
        <p class="label ct-section-label">Studio Contact</p>
        <div class="ct-row">
          <p class="label ct-key">Studio</p>
          <address class="ct-val">
            Jl. Dukuh Indah No.71, Umalas<br />
            Badung 80361, Bali, Indonesia
          </address>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Direct</p>
          <p class="ct-val">
            <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a><br />
            <a href="tel:+6282338888971">+62 823 3888 8971</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Hours</p>
          <p class="ct-val">Monday to Friday, 9.00-17.00 WITA</p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Catalog</p>
          <p class="ct-val">
            <a href="/assets/kamu-catalog.pdf" class="ct-link" download>Download the catalog</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Social</p>
          <p class="ct-val ct-social">
            <a href="https://instagram.com/kamuconcepts" target="_blank" rel="noopener">Instagram</a>
            <a href="https://tiktok.com/@kamuconcepts" target="_blank" rel="noopener">TikTok</a>
            <a href="https://pinterest.com/kamuconcepts" target="_blank" rel="noopener">Pinterest</a>
          </p>
        </div>
      </div>
    </div>

    <aside class="ct-note" data-reveal data-reveal-delay="0.2">
      <p class="label">Project Enquiry</p>
      <p>For new interiors, collaborations, or bespoke furniture, use Let's Talk.</p>
      <a href="/lets-talk/" class="ct-note-link">Start a project</a>
    </aside>
  </section>
</Base>

<style>
  .ct {
    padding-bottom: var(--space-xl);
    row-gap: var(--space-xl);
  }

  .ct-side {
    grid-column: 1 / 6;
    margin-top: clamp(3rem, 8vh, 6rem);
  }

  .ct-note {
    grid-column: 7 / 13;
    align-self: start;
    padding: var(--space-l);
    border: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
    border-radius: 1.5rem;
  }

  .ct-note p:not(.label) {
    margin-top: var(--space-s);
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: var(--lh-body);
  }

  .ct-note-link {
    display: inline-flex;
    margin-top: var(--space-m);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 1.2em 3.2em;
    background: var(--ink);
    color: var(--c-bone);
    border-radius: 999px;
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .ct-note-link:hover {
    background: var(--accent);
  }

  .ct-rows {
    margin-top: var(--space-m);
  }

  .ct-section-label {
    margin-bottom: 0.75rem;
    color: var(--ink-soft);
  }

  .ct-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-s);
    padding-block: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-key {
    color: var(--ink-soft);
    padding-top: 0.25em;
  }

  .ct-val {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .ct-val a {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .ct-val a:hover {
    color: var(--accent);
  }

  .ct-link {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .ct-social {
    display: flex;
    gap: var(--space-s);
  }

  @media (max-width: 56rem) {
    .ct-side,
    .ct-note {
      grid-column: 1 / -1;
    }

    .ct-side {
      margin-top: 0;
    }
  }
</style>
