---
/**
 * Contact — split canvas.
 * Left: studio image (dropped, echoing the project splits) over a
 * ruled ledger of studio facts. Right: the form as an editorial
 * questionnaire — numbered fields, large serif inputs, accent
 * focus line. Form has no backend yet — wired at Shopify launch.
 * Swap slot: contact-01.jpg.
 */
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';

// Warm, muted, architectural living room — calm lifestyle interior, on brand
const demo =
  'https://images.unsplash.com/photo-1540574163026-643ea20ade25?q=80&w=1600&auto=format&fit=crop';
---

<Base
  title="Contact"
  description="Talk to KAMU Concepts — interior design studio in Umalas, Bali. New projects, collaborations and product enquiries."
>
  <!-- ============ HEAD ============ -->
  <header class="page-head">
    <p class="label page-eyebrow" data-reveal>
      <span class="duo"><span>Contact</span><span class="duo-sub">Umalas, Bali</span></span>
    </p>
    <h1 class="page-title" data-reveal="line">Let&rsquo;s talk</h1>
    <p class="page-intro" data-reveal data-reveal-delay="0.15">
      We reply within two working days.
    </p>
  </header>

  <!-- ============ SPLIT CANVAS ============ -->
  <section class="ct grid-12">
    <!-- left: image + studio ledger -->
    <div class="ct-side">
      <div data-reveal="media">
        <Placeholder
          name="contact-01.jpg"
          ratio="3x4"
          demo={demo}
          alt="The KAMU studio in Umalas"
          parallax
        />
      </div>

      <div class="ct-rows" data-reveal data-reveal-delay="0.15">
        <div class="ct-row">
          <p class="label ct-key">Studio</p>
          <address class="ct-val">
            Jl. Dukuh Indah No.71, Umalas<br />
            Badung 80361, Bali, Indonesia
          </address>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Direct</p>
          <p class="ct-val">
            <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a><br />
            <a href="tel:+6282338888971">+62 823 3888 8971</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Hours</p>
          <p class="ct-val">Monday to Friday, 9.00&ndash;17.00 WITA</p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Catalog</p>
          <p class="ct-val">
            <a href="/assets/kamu-catalog.pdf" class="ct-link" download>Download the catalog</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Social</p>
          <p class="ct-val ct-social">
            <a href="https://instagram.com/kamuconcepts" target="_blank" rel="noopener">Instagram</a>
            <a href="https://tiktok.com/@kamuconcepts" target="_blank" rel="noopener">TikTok</a>
            <a href="https://pinterest.com/kamuconcepts" target="_blank" rel="noopener">Pinterest</a>
          </p>
        </div>
      </div>
    </div>

    <!-- right: the questionnaire -->
    <form class="ct-form" action="#" method="post">
      <p class="ct-form-lead" data-reveal>
        New project, collaboration, or a question about a piece —
        tell us what you&rsquo;re imagining.
      </p>

      <div class="ct-fld" data-reveal data-reveal-delay="0.1">
        <label class="label ct-fld-label" for="ct-name">
          <span class="duo"><span class="duo-num">01</span><span>Name</span></span>
        </label>
        <input type="text" id="ct-name" name="name" autocomplete="name" required />
      </div>

      <div class="ct-pair">
        <div class="ct-fld" data-reveal data-reveal-delay="0.15">
          <label class="label ct-fld-label" for="ct-email">
            <span class="duo"><span class="duo-num">02</span><span>Email</span></span>
          </label>
          <input type="email" id="ct-email" name="email" autocomplete="email" required />
        </div>
        <div class="ct-fld" data-reveal data-reveal-delay="0.2">
          <label class="label ct-fld-label" for="ct-phone">
            <span class="duo"><span class="duo-num">03</span><span>Phone</span></span>
          </label>
          <input type="tel" id="ct-phone" name="phone" autocomplete="tel" />
        </div>
      </div>

      <div class="ct-fld" data-reveal data-reveal-delay="0.25">
        <label class="label ct-fld-label" for="ct-message">
          <span class="duo"><span class="duo-num">04</span><span>Message</span></span>
        </label>
        <textarea id="ct-message" name="message" rows="4" required></textarea>
      </div>

      <div class="ct-actions" data-reveal data-reveal-delay="0.3">
        <button type="submit" class="ct-send">Send Message</button>
        <p class="caption ct-privacy">
          Your details stay with the studio. No lists, no noise.
        </p>
      </div>
    </form>
  </section>
</Base>

<style>


  /* ================= SPLIT ================= */
  .ct {
    padding-bottom: var(--space-xl);
    row-gap: var(--space-xl);
  }

  .ct-side {
    grid-column: 1 / 6;
    /* dropped, echoing the project split rhythm */
    margin-top: clamp(3rem, 8vh, 6rem);
  }

  .ct-form {
    grid-column: 7 / 13;
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  @media (max-width: 56rem) {
    .ct-side,
    .ct-form {
      grid-column: 1 / -1;
    }

    .ct-side {
      order: 2;
      margin-top: 0;
    }

    .ct-form {
      order: 1;
    }
  }

  /* ----- studio ledger ----- */
  .ct-rows {
    margin-top: var(--space-m);
  }

  .ct-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-s);
    padding-block: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-key {
    color: var(--ink-soft);
    padding-top: 0.25em;
  }

  .ct-val {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .ct-val a {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .ct-val a:hover {
    color: var(--accent);
  }

  .ct-link {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .ct-social {
    display: flex;
    gap: var(--space-s);
  }

  /* ----- the questionnaire ----- */
  .ct-form-lead {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: var(--lh-body);
    max-width: 32rem;
  }

  .ct-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
  }

  .ct-fld {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 28%, transparent);
  }

  /* accent line draws across on focus */
  .ct-fld::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .ct-fld:focus-within::after {
    transform: scaleX(1);
  }

  .ct-fld-label {
    color: var(--ink-soft);
  }

  .ct-fld input,
  .ct-fld textarea {
    background: none;
    border: none;
    outline: none;
    border-radius: 0;
    padding: 0 0 0.875rem;
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    color: var(--ink);
    resize: vertical;
  }

  .ct-actions {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-top: var(--space-2xs);
  }

  .ct-send {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 1.2em 3.2em;
    background: var(--ink);
    color: var(--c-bone);
    border-radius: 999px;
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .ct-send:hover {
    background: var(--accent);
  }

  .ct-privacy {
    max-width: 16rem;
    text-align: right;
  }

  @media (max-width: 40rem) {
    .ct-pair {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }

    .ct-privacy {
      text-align: left;
    }
  }
</style>
