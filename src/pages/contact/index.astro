---
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';
import SocialLinks from '../../components/SocialLinks.astro';

const demo =
  'https://images.unsplash.com/photo-1540574163026-643ea20ade25?q=80&w=1600&auto=format&fit=crop';
---

<Base
  title="Contact"
  description="Contact KAMU Concepts, interior design studio in Umalas, Bali."
>
  <header class="page-head">
    <p class="label page-eyebrow" data-reveal>
      <span class="duo"><span>Contact</span><span class="duo-sub">Umalas, Bali</span></span>
    </p>
    <h1 class="page-title" data-reveal="line">Contact</h1>
    <p class="page-intro" data-reveal data-reveal-delay="0.15">
      Studio address, direct contacts and social channels.
    </p>
  </header>

  <section class="ct grid-12" id="studio-contact">
    <div class="ct-side">
      <div data-reveal="media">
        <Placeholder
          name="contact-01.jpg"
          ratio="3x4"
          demo={demo}
          alt="The KAMU studio in Umalas"
          parallax
        />
      </div>
    </div>

    <div class="ct-main">
      <div class="ct-rows" data-reveal data-reveal-delay="0.15">
        <p class="label ct-section-label">Studio Contact</p>
        <div class="ct-row">
          <p class="label ct-key">Studio</p>
          <address class="ct-val">
            Jl. Dukuh Indah No.71, Umalas<br />
            Badung 80361, Bali, Indonesia
          </address>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Direct</p>
          <p class="ct-val">
            <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a>
            <br />
            <a href="https://wa.me/6282338888971">+62 823 3888 8971</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Hours</p>
          <p class="ct-val">Monday to Friday, 9.00-17.00 WITA</p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Catalog</p>
          <p class="ct-val">
            <a href="/assets/kamu-catalog.pdf" class="ct-link" download>Download the catalog</a>
          </p>
        </div>
        <div class="ct-row">
          <p class="label ct-key">Social</p>
          <div class="ct-val ct-social">
            <SocialLinks />
          </div>
        </div>
      </div>

      <section class="ct-enquiry" data-reveal data-reveal-delay="0.2">
        <div class="ct-enquiry-copy">
          <p class="label">Project Enquiry</p>
          <p>
            Tell the studio what you are planning, where it is, and what kind of
            support you need.
          </p>
        </div>

        <form class="ct-form" action="#" method="post">
          <div class="ct-fld">
            <label class="label ct-fld-label" for="lt-name">
              <span class="duo"><span class="duo-num">01</span><span>Name</span></span>
            </label>
            <input type="text" id="lt-name" name="name" autocomplete="name" required />
          </div>

          <div class="ct-pair">
            <div class="ct-fld">
              <label class="label ct-fld-label" for="lt-email">
                <span class="duo"><span class="duo-num">02</span><span>Email</span></span>
              </label>
              <input type="email" id="lt-email" name="email" autocomplete="email" required />
            </div>
            <div class="ct-fld">
              <label class="label ct-fld-label" for="lt-phone">
                <span class="duo"><span class="duo-num">03</span><span>Phone</span></span>
              </label>
              <input type="tel" id="lt-phone" name="phone" autocomplete="tel" />
            </div>
          </div>

          <div class="ct-fld">
            <label class="label ct-fld-label" for="lt-message">
              <span class="duo"><span class="duo-num">04</span><span>Project brief</span></span>
            </label>
            <textarea id="lt-message" name="message" rows="5" required></textarea>
          </div>

          <div class="ct-actions">
            <button type="submit" class="ct-send">Send Enquiry</button>
            <p class="caption ct-privacy">
              The form is visual only for this static preview.
            </p>
          </div>
        </form>
      </section>
    </div>
  </section>
</Base>

<style>
  .ct {
    padding-bottom: var(--space-xl);
    row-gap: var(--space-xl);
  }

  .ct-side {
    grid-column: 1 / 6;
    margin-top: clamp(3rem, 8vh, 6rem);
  }

  .ct-main {
    grid-column: 7 / 13;
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .ct-rows {
    margin-top: 0;
  }

  .ct-section-label {
    margin-bottom: 0.75rem;
    color: var(--ink-soft);
  }

  .ct-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-s);
    padding-block: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .ct-key {
    color: var(--ink-soft);
    padding-top: 0.25em;
  }

  .ct-val {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .ct-val a {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .ct-val a:hover {
    color: var(--accent);
  }

  .ct-link {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .ct-social {
    display: flex;
    align-items: center;
  }

  .ct-enquiry {
    margin-top: var(--space-m);
    padding: var(--space-l);
    border: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
    border-radius: 1.5rem;
  }

  .ct-enquiry-copy p:not(.label) {
    margin-top: var(--space-s);
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    line-height: var(--lh-body);
  }

  .ct-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    margin-top: var(--space-l);
  }

  .ct-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
  }

  .ct-fld {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 28%, transparent);
  }

  .ct-fld-label {
    color: var(--ink-soft);
  }

  .ct-fld input,
  .ct-fld textarea {
    background: none;
    border: none;
    outline: none;
    border-radius: 0;
    padding: 0 0 0.875rem;
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    color: var(--ink);
    resize: vertical;
  }

  .ct-actions {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .ct-send {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    padding: 1.2em 3.2em;
    background: var(--ink);
    color: var(--c-bone);
    border-radius: 999px;
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .ct-send:hover {
    background: var(--accent);
  }

  .ct-privacy {
    max-width: 16rem;
    text-align: right;
  }

  @media (max-width: 56rem) {
    .ct-side,
    .ct-main {
      grid-column: 1 / -1;
    }

    .ct-side {
      margin-top: 0;
    }
  }

  @media (max-width: 40rem) {
    .ct-pair {
      grid-template-columns: 1fr;
    }

    .ct-privacy {
      text-align: left;
    }
  }
</style>
