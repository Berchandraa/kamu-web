  }

  /* ================= LOOKBOOK ================= */
  .lookbook {
    background: var(--c-bone);
    color: var(--ink);
    padding-top: clamp(4.5rem, 8vw, 7rem);
  }

  .lookbook-head {
    padding-inline: var(--gutter);
    margin-bottom: clamp(3rem, 6vw, 5rem);
    text-align: center;
  }

  .lookbook-title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.04em;
  }

  .lookbook-intro {
    max-width: 42rem;
    margin: 1.4rem auto 0;
    color: var(--ink-soft);
    font-size: clamp(0.95rem, 1.15vw, 1.1rem);
    line-height: 1.45;
  }

  .lookbook-stage {
    position: relative;
    height: clamp(28rem, 55vw, 43rem);
    overflow: hidden;
    background: var(--c-black);
  }

  .lookbook-slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  .lookbook-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .lookbook-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lookbook-slide::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgb(0 0 0 / 0.38), transparent 42%),
      linear-gradient(0deg, rgb(0 0 0 / 0.25), transparent 34%);
    pointer-events: none;
  }

  .lookbook-label {
    position: absolute;
    z-index: 2;
    top: clamp(1.25rem, 2vw, 2rem);
    left: var(--gutter);
    color: var(--c-bone);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.01em;
  }

  .lookbook-arrow {
    position: absolute;
    z-index: 3;
    top: 50%;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: var(--c-bone);
    background: rgb(255 255 255 / 0.16);
    transform: translateY(-50%);
    backdrop-filter: blur(10px);
    font-size: 1.8rem;
    line-height: 1;
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .lookbook-arrow:hover {
    background: rgb(255 255 255 / 0.28);
  }

  .lookbook-prev {
    left: clamp(1rem, 2vw, 2rem);
  }

