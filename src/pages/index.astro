---
/**
 * Home.
 * Yodezeen: hero IS the media — full-bleed video, text floats on it.
 * Bureau: full-bleed editorial project showcase, asymmetric splits.
 * Sawdust: clean shop teaser.
 *
 * All media slots are swap-safe: drop the named file into
 * /public/assets/ and it replaces the Unsplash demo automatically.
 */
import Base from '../layouts/Base.astro';
import Preloader from '../components/Preloader.astro';
import Placeholder from '../components/Placeholder.astro';
import CTA from '../components/CTA.astro';
import { projects as allProjects } from '../data/projects';
import { products as allProducts } from '../data/products';

const projectBySlug = (slug: string) => allProjects.find((project) => project.slug === slug)!;
const projects = [
  projectBySlug('yucca-villas-studio'),
  projectBySlug('villa-kamal'),
  projectBySlug('villa-bocce'),
];

const homeProjectImages = [
  '/assets/home/selected-project-01.jpg',
  '/assets/home/selected-project-02.jpg',
  '/assets/home/selected-project-03.jpg',
];
const homePieceImages = [
  '/assets/home/furniture-01.jpg',
  '/assets/home/furniture-05.jpg',
  '/assets/home/furniture-03.jpg',
  '/assets/home/furniture-04.jpg',
  '/assets/home/furniture-02.jpg',
];
const pieces = allProducts
  .slice(0, 5)
  .map((product, i) => ({ ...product, demo: homePieceImages[i] ?? product.demo }));
const lookbook = [
  {
    label: '01 / Luxury Lounge Chair',
    image: '/assets/home/furniture-lookbook-01.jpg',
    alt: 'Luxury Lounge Chair in a curated living space',
  },
  {
    label: '02 / Coastal Lounge Setting',
    image: '/assets/home/furniture-lookbook-02.jpg',
    alt: 'Coastal lounge setting',
  },
  {
    label: '03 / Dining Table Study',
    image: '/assets/home/furniture-lookbook-03.jpg',
    alt: 'Dining table study by KAMU',
  },
  {
    label: '04 / Dining Room Edit',
    image: '/assets/home/furniture-lookbook-04.jpg',
    alt: 'Dining room edit by KAMU',
  },
];
---

<Base title="Interior Design Studio, Bali">
  <Preloader />

  <!-- ============ HERO — full-bleed video, text floats on it ============ -->
  <section class="hero" data-nav-invert>
    <div class="hero-media">
      {/* poster shows the home asset now; add src="/assets/hero-video.mp4" when the film lands */}
      <video
        poster="/assets/home/cover-page.jpg"
        data-swap="hero-video.mp4"
        autoplay
        muted
        loop
        playsinline
      ></video>
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="hero-text">
      <p class="hero-eyebrow label hero-el">
        <span class="duo"><span>Interior Design Studio</span><span class="duo-sub">Bali</span></span>
      </p>
      <h1 class="display hero-headline">
        <span class="hero-line"><span class="hero-el">We design houses</span></span>
        <span class="hero-line"><span class="hero-el">we want to live in</span></span>
      </h1>
    </div>

    <p class="hero-quote quote hero-el">
      &ldquo;Your home should feel like an exhale.&rdquo;
    </p>
  </section>

  <!-- ============ MANIFESTO — asymmetric editorial statement ============ -->
  <section class="manifesto">
    <div class="grid-12">
      <p class="label manifesto-label" data-reveal>The Studio</p>
      <h2 class="h1 manifesto-statement" data-reveal="line">
        Interiors rooted in craftsmanship, natural materials and thoughtful
        living.
      </h2>
      <div class="manifesto-body" data-reveal data-reveal-delay="0.15">
        <p>
          From first concept to final detail, we craft personalized spaces
          that reflect how you actually live — calm, balanced, and built to
          last. Atmosphere over decoration, always.
        </p>
        <a href="/about/" class="text-link label">About the studio</a>
      </div>
    </div>
  </section>

  <section class="studio-panel" aria-labelledby="studio-panel-title">
    <figure class="studio-panel-media" data-reveal="media">
      <img src="/assets/home/ceo-picture-fill.jpg" alt="KAMU Concepts founder portrait" loading="lazy" />
      <figcaption>KAMU Concepts Studio</figcaption>
    </figure>

    <div class="studio-panel-copy" data-reveal>
      <p class="label studio-panel-eyebrow">About Us</p>
      <h2 id="studio-panel-title" class="studio-panel-title">KAMU Concepts</h2>
      <p class="label studio-panel-subtitle">Studio and Design</p>
      <span class="studio-panel-rule" aria-hidden="true"></span>
      <p class="studio-panel-text">
        We design homes around the way people actually live: calm proportions,
        natural materials, and details that feel personal rather than
        decorative. From spatial planning to bespoke furniture, each project is
        shaped through conversation, restraint, and craft.
      </p>

      <div class="studio-panel-values" aria-label="KAMU Concepts values">
        <span><small>01</small>Craft</span>
        <span><small>02</small>Material</span>
        <span><small>03</small>Living</span>
      </div>

      <a href="/about/" class="studio-panel-link">
        <span>Read more about us</span>
        <span aria-hidden="true">+</span>
      </a>
    </div>
  </section>

  <!-- ============ SELECTED WORK — Bureau: full-bleed, asymmetric ============ -->
  <section class="work">
    <header class="work-head grid-12">
      <h2 class="display work-title" data-reveal="line">Selected<br />Work</h2>
      <p class="label work-count" data-reveal>
        <span class="duo"><span>Projects</span><span class="duo-num">03</span></span>
      </p>
    </header>

    <!-- Feature: edge to edge -->
    <a href={`/projects/${projects[0].slug}/`} class="feature" data-parallax>
      <img
        src={homeProjectImages[0]}
        alt={projects[0].name}
      />
      <div class="feature-caption">
        <h3 class="h2">{projects[0].name}</h3>
        <p class="label feature-meta duo">
          <span>{projects[0].location}</span><span class="duo-sub">{projects[0].type}</span>
        </p>
      </div>
    </a>

    <!-- Asymmetric split: 62 / 38, right column dropped -->
    <div class="work-split">
      <a href={`/projects/${projects[1].slug}/`} class="work-item work-item-a" data-reveal="media">
        <Placeholder
          name={projects[1].file}
          ratio="4x3"
          demo={homeProjectImages[1]}
          alt={projects[1].name}
          parallax
        />
        <div class="work-item-caption">
          <h3 class="h2">{projects[1].name}</h3>
          <p class="label work-item-meta duo"><span>{projects[1].location}</span><span class="duo-sub">{projects[1].type}</span></p>
        </div>
      </a>

      <a href={`/projects/${projects[2].slug}/`} class="work-item work-item-b" data-reveal="media" data-reveal-delay="0.15">
        <Placeholder
          name={projects[2].file}
          ratio="3x4"
          demo={homeProjectImages[2]}
          alt={projects[2].name}
          parallax
        />
        <div class="work-item-caption">
          <h3 class="h2">{projects[2].name}</h3>
          <p class="label work-item-meta duo"><span>{projects[2].location}</span><span class="duo-sub">{projects[2].type}</span></p>
        </div>
      </a>
    </div>

    <div class="work-all grid-12">
      <a href="/projects/" class="text-link label" data-reveal>All projects</a>
    </div>
  </section>

  <section class="lookbook" aria-labelledby="lookbook-title">
    <header class="lookbook-head">
      <h2 id="lookbook-title" class="lookbook-title" data-reveal="line">
        THE LIVING LOOKBOOK
      </h2>
      <p class="lookbook-intro" data-reveal data-reveal-delay="0.1">
        Explore curated spaces designed with architectural intentionality.<br />
        Discover the pieces that define the KAMU aesthetic.
      </p>
    </header>

    <div class="lookbook-stage" data-reveal="media">
      {
        lookbook.map((item, i) => (
          <figure class={`lookbook-slide ${i === 0 ? 'is-active' : ''}`} aria-hidden={i === 0 ? 'false' : 'true'}>
            <img src={item.image} alt={item.alt} loading={i === 0 ? 'eager' : 'lazy'} />
            <figcaption class="lookbook-label">{item.label}</figcaption>
          </figure>
        ))
      }

      <button class="lookbook-arrow lookbook-prev" type="button" data-lookbook-prev aria-label="Previous lookbook slide">
        ‹
      </button>
      <button class="lookbook-arrow lookbook-next" type="button" data-lookbook-next aria-label="Next lookbook slide">
        ›
      </button>

      <div class="lookbook-dots" aria-label="Lookbook slides">
        {
          lookbook.map((_, i) => (
            <button
              class={`lookbook-dot ${i === 0 ? 'is-active' : ''}`}
              type="button"
              data-lookbook-dot={i}
              aria-label={`Show lookbook slide ${i + 1}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ PHILOSOPHY — mist band ============ -->
  <section class="philosophy">
    <div class="grid-12">
      <p class="philosophy-quote" data-reveal="line">
        Atmosphere over decoration. Handmade elements, natural textures, and
        warm neutral tones — spaces that feel calm, lived-in and effortlessly
        inviting.
      </p>
      <p class="label philosophy-credit" data-reveal data-reveal-delay="0.2">
        Slow Tropical Living
      </p>
    </div>
  </section>

  <!-- ============ COLLECTION — Sawdust: clean e-comm row ============ -->
  <section class="collection">
    <header class="collection-head">
      <p class="label collection-eyebrow" data-reveal>
        <span class="duo"><span>by KAMU</span><span class="duo-sub">Explore Our Pieces</span></span>
      </p>
      <h2 class="collection-title" data-reveal="line">
        High-Quality Furniture<br /><em>for Bespoke Homes</em>
      </h2>
    </header>

    <div class="collection-row" id="collection-row">
      {
        pieces.map((p, i) => (
          <a
            href={`/shop/${p.slug}/`}
            class="collection-card"
            data-reveal
            data-reveal-delay={String(i * 0.08)}
            draggable="false"
          >
            <Placeholder name={p.file} ratio="3x4" demo={p.demo} alt={p.name} />
            <div class="collection-caption">
              <h3 class="collection-name">{p.name}</h3>
              <p class="caption collection-price">{p.price}</p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="collection-foot" data-reveal>
      <a href="/shop/" class="collection-cta">Shop Now</a>
    </div>
  </section>

  <CTA />
</Base>

<style>
  /* (grid-12 + text-link live in global.css) */

  /* ================= HERO ================= */
  .hero {
    position: relative;
    height: 100svh;
    width: 100%;
    overflow: hidden;
    color: var(--c-bone);
  }

  .hero-media,
  .hero-media video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-media video {
    object-fit: cover;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to top,
        color-mix(in srgb, var(--c-black) 62%, transparent) 0%,
        transparent 45%
      ),
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--c-black) 30%, transparent) 0%,
        transparent 22%
      );
  }

  /* Headline bottom-left (brand placement grid) */
  .hero-text {
    position: absolute;
    z-index: 2;
    left: var(--gutter);
    bottom: clamp(2.5rem, 7vh, 5rem);
    max-width: 80%;
  }

  .hero-eyebrow {
    margin-bottom: var(--space-s);
    color: color-mix(in srgb, var(--c-bone) 80%, transparent);
  }

  .hero-headline {
    text-transform: uppercase;
  }

  .hero-line {
    display: block;
    overflow: hidden;
  }

  .hero-line > span {
    display: block;
  }

  /* Quote floats bottom-right — asymmetric counterweight */
  .hero-quote {
    position: absolute;
    z-index: 2;
    right: var(--gutter);
    bottom: clamp(2.5rem, 7vh, 5rem);
    max-width: 17rem;
    text-align: right;
    font-size: 1rem;
    color: color-mix(in srgb, var(--c-bone) 85%, transparent);
  }

  /* Hero intro: hidden until preloader hands off (JS sets visible) */
  @media (prefers-reduced-motion: no-preference) {
    html:not(.no-js) .hero-el {
      opacity: 0;
    }
  }

  @media (max-width: 56rem) {
    .hero-quote {
      display: none;
    }

    .hero-text {
      max-width: 92%;
    }
  }

  /* ================= MANIFESTO ================= */
  .manifesto {
    padding-block: var(--space-2xl);
  }

  .manifesto-label {
    grid-column: 1 / 3;
    color: var(--ink);
    padding-top: 0.75rem;
  }

  .manifesto-statement {
    grid-column: 4 / 13;
    text-wrap: balance;
  }

  .manifesto-body {
    grid-column: 7 / 12;
    margin-top: var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    color: var(--ink-soft);
  }

  /* Pull-quote: Lora italic, high-contrast ink (#202020) — never the
     terracotta accent, which is accent-only and not for body copy. */
  .manifesto-body p {
    color: var(--ink);
    font-style: italic;
    font-size: var(--fs-sub);
    line-height: var(--lh-body);
  }

  @media (max-width: 56rem) {
    .manifesto-label {
      grid-column: 1 / -1;
      margin-bottom: var(--space-s);
    }

    .manifesto-statement {
      grid-column: 1 / -1;
    }

    .manifesto-body {
      grid-column: 2 / -1;
    }
  }

  /* ================= STUDIO PANEL ================= */
  .studio-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    min-height: min(58rem, 92svh);
    margin-bottom: var(--space-xl);
    background: var(--bg-alt);
  }

  .studio-panel-media {
    position: relative;
    min-height: 42rem;
    margin: 0;
    overflow: hidden;
  }

  .studio-panel-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .studio-panel-media figcaption {
    position: absolute;
    left: var(--gutter);
    bottom: var(--space-m);
    color: var(--c-bone);
    font-size: 0.72rem;
  }

  .studio-panel-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(4rem, 8vw, 8rem) var(--gutter);
  }

  .studio-panel-eyebrow,
  .studio-panel-subtitle {
    color: var(--ink-soft);
  }

  .studio-panel-title {
    margin-top: var(--space-s);
    color: var(--ink);
    font-size: clamp(2.25rem, 4vw, 4.25rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .studio-panel-subtitle {
    margin-top: var(--space-s);
  }

  .studio-panel-rule {
    width: 3.25rem;
    height: 1px;
    margin-top: var(--space-l);
    background: var(--accent-soft);
  }

  .studio-panel-text {
    max-width: 34rem;
    margin-top: var(--space-l);
    color: var(--ink);
    font-size: clamp(1.1rem, 1.45vw, 1.45rem);
    line-height: 1.45;
  }

  .studio-panel-values {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-s);
    max-width: 34rem;
    margin-top: var(--space-l);
  }

  .studio-panel-values span {
    display: flex;
    min-height: 3.5rem;
    flex-direction: column;
    justify-content: end;
    gap: 0.55rem;
    border-right: 1px solid color-mix(in srgb, var(--ink-soft) 26%, transparent);
    color: var(--ink);
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
  }

  .studio-panel-values span:last-child {
    border-right: 0;
  }

  .studio-panel-values small {
    color: var(--accent);
    font-size: 0.66rem;
  }

  .studio-panel-link {
    display: inline-flex;
    width: max-content;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-l);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--ink);
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 650;
  }

  @media (max-width: 56rem) {
    .studio-panel {
      grid-template-columns: 1fr;
    }

    .studio-panel-media {
      min-height: 65vh;
    }

    .studio-panel-copy {
      padding-block: var(--space-xl);
    }

    .studio-panel-values {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .studio-panel-values span {
      border-right: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--ink-soft) 22%, transparent);
      padding-bottom: var(--space-xs);
    }
  }

  /* ================= WORK ================= */
  .work-head {
    align-items: end;
    margin-bottom: var(--space-l);
  }

  .work-title {
    grid-column: 1 / 9;
    text-transform: uppercase;
  }

  .work-count {
    grid-column: 11 / 13;
    justify-self: end;
    color: var(--ink-soft);
    padding-bottom: 1rem;
  }

  /* Feature — true full bleed, tall */
  .feature {
    position: relative;
    display: block;
    width: 100%;
    height: min(92svh, 60rem);
    overflow: hidden;
  }

  .feature img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feature-caption {
    position: absolute;
    left: var(--gutter);
    bottom: var(--space-m);
    z-index: 2;
    color: var(--c-bone);
  }

  .feature::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--c-black) 55%, transparent) 0%,
      transparent 38%
    );
  }

  .feature-caption {
    z-index: 2;
  }

  .feature-meta {
    margin-top: 0.5rem;
    opacity: 0.8;
  }

  /* Asymmetric split — minimal gap, right column dropped */
  .work-split {
    display: grid;
    grid-template-columns: 62fr 38fr;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .work-item {
    display: block;
  }

  .work-item-b {
    margin-top: clamp(4rem, 12vh, 9rem);
  }

  .work-item-caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    padding: 1rem var(--gutter) 0;
  }

  .work-item-caption .h2 {
    font-size: clamp(1.125rem, 1.8vw, 1.5rem);
  }

  .work-item-meta {
    color: var(--ink-soft);
    white-space: nowrap;
  }

  /* Wide counterweight, pushed right */
  .work-wide {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: repeat(12, 1fr);
  }

  .work-wide .work-item {
    grid-column: 4 / 13;
  }

  .work-all {
    margin-top: var(--space-l);
  }

  .work-all .text-link {
    grid-column: 1 / 4;
  }

  @media (max-width: 56rem) {
    .work-title {
      grid-column: 1 / -1;
    }

    .work-count {
      grid-column: 1 / -1;
      justify-self: start;
      margin-top: var(--space-2xs);
    }

    .feature {
      height: 70svh;
    }

    .work-split {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }

    .work-item-b {
      margin-top: 0;
      width: 78%;
      margin-left: auto;
    }

    .work-wide .work-item {
      grid-column: 1 / -1;
    }
  }

  /* ================= PHILOSOPHY ================= */
  .philosophy {
    margin-top: var(--space-2xl);
    background: var(--natural);
    color: var(--c-bone);
    padding-block: var(--space-2xl);
  }

  /* Montserrat, bone on the mist-green band — clean, modern, well-weighted
     for strong contrast (not a faint serif overlay). */
  .philosophy-quote {
    grid-column: 2 / 11;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--c-bone);
    text-wrap: balance;
  }

  .philosophy-credit {
    grid-column: 2 / 8;
    margin-top: var(--space-l);
    color: color-mix(in srgb, var(--c-bone) 78%, transparent);
  }

  @media (max-width: 56rem) {
    .philosophy-quote,
    .philosophy-credit {
      grid-column: 1 / -1;
    }
  }

  /* ================= COLLECTION — Sawdust ================= */
  .collection {
    padding-block: var(--space-2xl) 0;
  }

  .collection-head {
    text-align: center;
    padding-inline: var(--gutter);
    margin-bottom: var(--space-xl);
  }

  .collection-eyebrow {
    color: var(--ink);
    margin-bottom: var(--space-s);
  }

  .collection-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-snug);
    text-wrap: balance;
  }

  .collection-title em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  /* Sliding row — drag or scroll sideways, next card peeks */
  .collection-row {
    display: flex;
    gap: clamp(1.5rem, 3vw, 3rem);
    overflow-x: auto;
    padding-inline: var(--gutter);
    padding-bottom: var(--space-s);
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
  }

  .collection-row::-webkit-scrollbar {
    display: none;
  }

  .collection-row.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .collection-row.is-dragging .collection-card {
    pointer-events: none;
  }

  .collection-card {
    flex: 0 0 clamp(15rem, 26vw, 23rem);
    scroll-snap-align: start;
    user-select: none;
  }

  .collection-card :global(.media) {
    background: var(--bg-alt);
  }

  .collection-card :global(img) {
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .collection-card:hover :global(img) {
    transform: scale(1.04);
  }

  .collection-caption {
    text-align: center;
    padding-top: var(--space-s);
  }

  .collection-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
