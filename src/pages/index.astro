    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.35);
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .lookbook-dot.is-active {
    background: var(--c-bone);
  }

  @media (max-width: 48rem) {
    .lookbook-head {
      margin-bottom: 2.75rem;
    }

    .lookbook-stage {
      height: 68vh;
      min-height: 30rem;
    }
  }

</style>

<script>
  import { gsap } from 'gsap';

  // Hero intro — waits for the preloader curtain (kamu:ready)
  const intro = () => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = document.querySelectorAll<HTMLElement>('.hero-el');

    if (reduced) {
      els.forEach((el) => (el.style.opacity = '1'));
      return;
    }

    gsap
      .timeline({ defaults: { ease: 'power3.out' } })
      .fromTo(
        '.hero-line > .hero-el',
        { yPercent: 110, opacity: 1 },
        { yPercent: 0, duration: 1.4, stagger: 0.12 },
        0.1
      )
      .fromTo(
        '.hero-eyebrow',
        { y: 16, opacity: 0 },
        { y: 0, opacity: 1, duration: 1 },
        0.5
      )
      .fromTo(
        '.hero-quote',
        { y: 16, opacity: 0 },
        { y: 0, opacity: 1, duration: 1.2 },
        0.8
      );
  };

  if ((window as any).__kamuReady) {
    intro();
  } else {
    window.addEventListener('kamu:ready', intro, { once: true });
  }

  // Collection row — drag to scroll sideways
  const row = document.getElementById('collection-row');
  if (row) {
    let startX = 0;
    let startScroll = 0;
    let dragging = false;

    row.addEventListener('pointerdown', (e) => {
      dragging = true;
      startX = e.clientX;
      startScroll = row.scrollLeft;
      row.setPointerCapture(e.pointerId);
    });

    row.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      // only enter drag mode after a small threshold so clicks still work
      if (Math.abs(dx) > 6) row.classList.add('is-dragging');
      row.scrollLeft = startScroll - dx;
    });

    const endDrag = () => {
      dragging = false;
      row.classList.remove('is-dragging');
    };

    row.addEventListener('pointerup', endDrag);
    row.addEventListener('pointercancel', endDrag);
  }

  const lookbookSlides = [...document.querySelectorAll<HTMLElement>('.lookbook-slide')];
  const lookbookDots = [...document.querySelectorAll<HTMLButtonElement>('.lookbook-dot')];
  let lookbookIndex = 0;

  const setLookbook = (next: number) => {
    if (!lookbookSlides.length) return;
    lookbookIndex = (next + lookbookSlides.length) % lookbookSlides.length;

    lookbookSlides.forEach((slide, i) => {
      const active = i === lookbookIndex;
      slide.classList.toggle('is-active', active);
      slide.setAttribute('aria-hidden', active ? 'false' : 'true');
    });

    lookbookDots.forEach((dot, i) => {
      dot.classList.toggle('is-active', i === lookbookIndex);
    });
  };

  document
    .querySelector<HTMLButtonElement>('[data-lookbook-prev]')
    ?.addEventListener('click', () => setLookbook(lookbookIndex - 1));

  document
    .querySelector<HTMLButtonElement>('[data-lookbook-next]')
    ?.addEventListener('click', () => setLookbook(lookbookIndex + 1));

  lookbookDots.forEach((dot, i) => {
    dot.addEventListener('click', () => setLookbook(i));
  });
</script>

