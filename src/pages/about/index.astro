---
/**
 * About Us — editorial, calm, Bureau scale.
 * Content from the brand PDF: brand story (p.5), vision/mission (p.4),
 * values (p.4). Swap slots: about-01.jpg … about-03.jpg.
 */
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';
import CTA from '../../components/CTA.astro';

const u = (id: string, w = 1800) =>
  `https://images.unsplash.com/photo-${id}?q=80&w=${w}&auto=format&fit=crop`;

// Values per the brand guidelines (p.4) — names only, exactly as written.
const values = [
  { n: '01', name: 'Creativity & Innovation' },
  { n: '02', name: 'Quality & Precision' },
  { n: '03', name: 'Client-Centric Approach' },
  { n: '04', name: 'Sustainability & Ethical Sourcing' },
];
---

<Base
  title="About"
  description="KAMU Concepts — a Bali interior design studio rooted in craftsmanship, natural materials and thoughtful living."
>
  <!-- ============ HERO STATEMENT ============ -->
  <header class="page-head">
    <p class="label page-eyebrow" data-reveal>
      <span class="duo"><span>About</span><span class="duo-sub">KAMU Concepts</span></span>
    </p>
    <h1 class="page-title" data-reveal="line">
      Your home should<br />feel like an exhale
    </h1>
  </header>

  <div class="ab-hero" data-reveal="media">
    <Placeholder
      name="about-01.jpg"
      ratio="21x9"
      demo={u('1600585154340-be6161a56a0c', 2400)}
      alt="KAMU Concepts studio"
      parallax
    />
  </div>

  <!-- ============ BRAND STORY ============ -->
  <section class="ab-story grid-12">
    <p class="label ab-story-label" data-reveal>Brand Story</p>
    <p class="ab-story-lead" data-reveal="line">
      KAMU Concepts was created from a deep appreciation for craftsmanship,
      natural materials and thoughtful living.
    </p>
    <div class="ab-story-body" data-reveal data-reveal-delay="0.15">
      <p>
        Rooted in timeless design and handcrafted detail, the brand combines
        locally made products with a modern, refined aesthetic. Each piece is
        carefully designed to bring warmth, texture and balance into
        contemporary spaces. Inspired by organic forms, earthy tones, and the
        beauty of slow interiors, KAMU Concepts embraces the harmony between
        traditional craftsmanship and modern living.
      </p>
      <p>
        More than a furniture brand, KAMU Concepts represents a lifestyle
        centered around intentional spaces — spaces that feel calm, lived-in
        and effortlessly inviting.
      </p>
    </div>
  </section>

  <!-- ============ VISION / MISSION ============ -->
  <section class="ab-vm" aria-label="Vision and Mission">
    <article class="ab-vm-row" data-reveal>
      <figure class="ab-vm-media">
        <img src="/assets/home/ceo-picture.jpg" alt="KAMU Concepts founder portrait" loading="lazy" />
      </figure>
      <div class="ab-vm-copy">
        <p class="label ab-vm-label">/ Vision</p>
        <p class="ab-vm-text">
          To be a leading interior design studio known for timeless, modern,
          and luxury aesthetics with a strong commitment to quality and
          attention to detail.
        </p>
      </div>
    </article>

    <article class="ab-vm-row ab-vm-row-reverse" data-reveal data-reveal-delay="0.12">
      <div class="ab-vm-copy">
        <p class="label ab-vm-label">/ Mission</p>
        <p class="ab-vm-text">
          To create innovative and personalized interior design solutions that
          reflect our clients&rsquo; unique lifestyles and aspirations.
        </p>
      </div>
      <figure class="ab-vm-media">
        <img src="/assets/home/team-picture.jpg" alt="KAMU Concepts team portrait" loading="lazy" />
      </figure>
    </article>
  </section>

  <!-- ============ VALUES — dark band ============ -->
  <section class="ab-values">
    <div class="ab-values-inner">
      <h2 class="ab-values-title" data-reveal="line">What we hold onto</h2>

      <ol class="ab-values-list">
        {
          values.map((v, i) => (
            <li class="ab-value" data-reveal data-reveal-delay={String(i * 0.08)}>
              <span class="ab-value-n">{v.n}</span>
              <span class="ab-value-name">{v.name}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ STUDIO — asymmetric split ============ -->
  <section class="ab-studio">
    <div class="ab-studio-split">
      <div data-reveal="media">
        <Placeholder
          name="about-02.jpg"
          ratio="4x3"
          demo={u('1556911220-bff31c812dba')}
          alt="The KAMU workshop"
          parallax
        />
      </div>
      <div class="ab-studio-dropped" data-reveal="media" data-reveal-delay="0.15">
        <Placeholder
          name="about-03.jpg"
          ratio="3x4"
          demo={u('1493809842364-78817add7ffb', 1200)}
          alt="Material studies"
          parallax
        />
      </div>
    </div>
    <div class="grid-12 ab-studio-foot">
      <p class="quote ab-studio-quote" data-reveal="line">
        From statement furniture to curated home pieces, every collection is
        created with attention to quality, simplicity and lasting character.
      </p>
    </div>
  </section>

  <CTA />
</Base>

<style>
  /* ================= STORY ================= */
  .ab-story {
    padding-block: var(--space-2xl);
    row-gap: var(--space-m);
  }

  .ab-story-label {
    grid-column: 1 / 3;
    color: var(--ink);
    padding-top: 0.5rem;
  }

  .ab-story-lead {
    grid-column: 1 / 9;
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    line-height: var(--lh-body);
  }

  .ab-story-body {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    color: var(--ink-soft);
  }

  @media (max-width: 56rem) {
    .ab-story-label,
    .ab-story-lead {
      grid-column: 1 / -1;
    }

    .ab-story-body {
      grid-column: 2 / -1;
    }
  }

  /* ================= VALUES — dark editorial list ================= */
  .ab-values {
    background: var(--ink);
    color: var(--c-bone);
    padding-block: var(--space-2xl);
  }

  .ab-values-inner {
    padding-inline: var(--gutter);
  }

  .ab-values-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-h2);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-snug);
    color: var(--c-bone);
    margin-bottom: var(--space-xl);
    max-width: 22ch;
  }

  /* Each value is a full-width row: index + name, generous breathing
     room, separated by hairline rules. Names only, per the guidelines. */
  .ab-values-list {
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 16%, transparent);
  }

  .ab-value {
    display: grid;
    grid-template-columns: 4rem 1fr;
    align-items: baseline;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding-block: clamp(1.75rem, 3.5vw, 3rem);
    border-bottom: 1px solid color-mix(in srgb, var(--c-bone) 16%, transparent);
  }

  .ab-value-n {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    color: var(--accent-soft);
  }

  .ab-value-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.5rem, 3.2vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-bone);
    text-wrap: balance;
  }

  @media (max-width: 40rem) {
    .ab-value {
      grid-template-columns: 2.5rem 1fr;
      gap: var(--space-s);
    }
  }

  /* ================= VISION / MISSION ================= */
  .ab-vm {
    padding-block: var(--space-xl) var(--space-2xl);
    background: var(--bg);
  }

  .ab-vm-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: clamp(32rem, 58vw, 44rem);
  }

  .ab-vm-media {
    min-height: inherit;
    margin: 0;
    overflow: hidden;
  }

  .ab-vm-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ab-vm-copy {
    min-height: inherit;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(3rem, 6vw, 6rem) var(--gutter);
  }

  .ab-vm-label {
    color: var(--ink-soft);
  }

  .ab-vm-text {
    max-width: 32rem;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    font-weight: 650;
    line-height: 1.14;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  @media (max-width: 56rem) {
    .ab-vm {
      padding-block: var(--space-l) var(--space-xl);
    }

    .ab-vm-row {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ab-vm-row-reverse .ab-vm-media {
      order: -1;
    }

    .ab-vm-media {
      min-height: 60vh;
    }

    .ab-vm-copy {
      min-height: 24rem;
      gap: var(--space-xl);
    }
  }

  /* ================= STUDIO ================= */
  .ab-studio-split {
    display: grid;
    grid-template-columns: 58fr 42fr;
    gap: 0.25rem;
  }

  .ab-studio-dropped {
    margin-top: clamp(4rem, 12vh, 9rem);
  }

  .ab-studio-foot {
    padding-block: var(--space-2xl) 0;
    row-gap: var(--space-m);
  }

  /* Grid-anchored editorial pull-quote (Lora italic) — a hairline rule
     gives it structure instead of floating it loosely in the middle. */
  .ab-studio-quote {
    grid-column: 2 / 11;
    padding-top: var(--space-l);
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    line-height: var(--lh-body);
    color: var(--ink);
    text-wrap: balance;
  }

  .ab-studio-link {
    grid-column: 2 / 6;
  }

  @media (max-width: 56rem) {
    .ab-studio-split {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }

    .ab-studio-dropped {
      margin-top: 0;
      width: 80%;
      margin-left: auto;
    }

    .ab-studio-quote,
    .ab-studio-link {
      grid-column: 1 / -1;
    }
  }
</style>
