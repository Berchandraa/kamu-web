---
/**
 * About Us — editorial, calm, Bureau scale.
 * Content from the brand PDF: brand story (p.5), vision/mission (p.4),
 * values (p.4). Swap slots: about-01.jpg … about-03.jpg.
 */
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';

const u = (id: string, w = 1800) =>
  `https://images.unsplash.com/photo-${id}?q=80&w=${w}&auto=format&fit=crop`;

// Values per the brand guidelines (p.4); descriptions are short site copy.
const values = [
  {
    n: '01',
    name: 'Creativity & Innovation',
    desc: 'We shape each brief with fresh thinking, thoughtful problem solving, and a clear sense of how the space should feel.',
  },
  {
    n: '02',
    name: 'Quality & Precision',
    desc: 'Every proportion, material junction, and finish is considered so the final space feels calm, durable, and resolved.',
  },
  {
    n: '03',
    name: 'Client-Centric Approach',
    desc: 'We begin with the way our clients live, then translate their routines, taste, and aspirations into a personal design language.',
  },
  {
    n: '04',
    name: 'Sustainability & Ethical Sourcing',
    desc: 'We prefer honest materials, responsible sourcing, and long-lasting pieces that age with the home rather than chase trends.',
  },
];
---

<Base
  title="About"
  description="KAMU Concepts — a Bali interior design studio rooted in craftsmanship, natural materials and thoughtful living."
>
  <!-- ============ HERO STATEMENT ============ -->
  <header class="page-head">
    <p class="label page-eyebrow" data-reveal>
      <span class="duo"><span>About</span><span class="duo-sub">KAMU Concepts</span></span>
    </p>
    <h1 class="page-title" data-reveal="line">
      Your home should<br />feel like an exhale
    </h1>
  </header>

  <div class="ab-hero" data-reveal="media">
    <Placeholder
      name="about-01.jpg"
      ratio="21x9"
      demo={u('1600585154340-be6161a56a0c', 2400)}
      alt="KAMU Concepts studio"
      parallax
    />
  </div>

  <!-- ============ BRAND STORY ============ -->
  <section class="ab-story grid-12">
    <p class="label ab-story-label" data-reveal>Brand Story</p>
    <p class="ab-story-lead" data-reveal="line">
      KAMU Concepts was created from a deep appreciation for craftsmanship,
      natural materials and thoughtful living.
    </p>
    <div class="ab-story-body" data-reveal data-reveal-delay="0.15">
      <p>
        Rooted in timeless design and handcrafted detail, the brand combines
        locally made products with a modern, refined aesthetic. Each piece is
        carefully designed to bring warmth, texture and balance into
        contemporary spaces. Inspired by organic forms, earthy tones, and the
        beauty of slow interiors, KAMU Concepts embraces the harmony between
        traditional craftsmanship and modern living.
      </p>
      <p>
        More than a furniture brand, KAMU Concepts represents a lifestyle
        centered around intentional spaces — spaces that feel calm, lived-in
        and effortlessly inviting.
      </p>
    </div>
  </section>

  <!-- ============ VISION / MISSION ============ -->
  <section class="ab-vm" aria-label="Vision and Mission">
    <article class="ab-vm-story">
      <div class="ab-vm-stack" aria-hidden="true">
        <div class="ab-vm-pin">
          <figure class="ab-vm-card is-active" data-vm-card="belief">
            <img src="/assets/home/ceo-picture-fill.jpg" alt="" loading="lazy" />
          </figure>
          <figure class="ab-vm-card" data-vm-card="work">
            <img src="/assets/home/team-picture.jpg" alt="" loading="lazy" />
          </figure>
        </div>
      </div>
      <div class="ab-vm-copy">
        <div class="ab-vm-step" data-vm-step="belief">
          <div class="ab-vm-step-card">
            <p class="label ab-vm-label">Our Belief</p>
            <h2 class="ab-vm-title">
              At Kamu Concepts, we believe that a well-designed space is never just
              about aesthetics. It&rsquo;s a reflection of the people who live in it.
            </h2>
            <p>
              This belief has shaped our vision from the very beginning, to become a
              leading interior design studio recognized for timeless, modern, and
              luxury aesthetics, built on an unwavering commitment to quality and
              attention to detail.
            </p>
            <blockquote>True luxury lives in the details often left unnoticed.</blockquote>
          </div>
        </div>
        <div class="ab-vm-step" data-vm-step="work">
          <div class="ab-vm-step-card">
            <p class="label ab-vm-label">How We Work</p>
            <h2 class="ab-vm-title">
              We don&rsquo;t believe in one-size-fits-all design.
            </h2>
            <p>
              Our mission is to craft innovative and personalized interior solutions
              that speak to each client&rsquo;s unique lifestyle and aspirations, spaces
              that don&rsquo;t just look beautiful, but feel like home.
            </p>
            <p>
              It&rsquo;s this dedication to understanding people first, and design second,
              that continues to guide everything we create at Kamu Concepts.
            </p>
          </div>
        </div>
      </div>
    </article>
  </section>

  <!-- ============ VALUES — dark band ============ -->
  <section class="ab-values">
    <div class="ab-values-inner">
      <h2 class="ab-values-title" data-reveal="line">What we hold onto</h2>

      <ol class="ab-values-list">
        {
          values.map((v, i) => (
            <li class="ab-value" data-reveal data-reveal-delay={String(i * 0.08)}>
              <span class="ab-value-n">{v.n}</span>
              <button class="ab-value-toggle" type="button" aria-expanded="false">
                <span class="ab-value-name">{v.name}</span>
              </button>
              <p class="ab-value-desc">{v.desc}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============ STUDIO — image ============ -->
  <section class="ab-studio">
    <figure class="ab-studio-image" data-reveal="media">
      <img src="/assets/home/cta-interior.jpg" alt="Warm interior detail by KAMU Concepts" loading="lazy" />
    </figure>
    <div class="grid-12 ab-studio-foot">
      <p class="quote ab-studio-quote" data-reveal="line">
        From statement furniture to curated home pieces, every collection is
        created with attention to quality, simplicity and lasting character.
      </p>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.ab-value-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const item = button.closest('.ab-value');
        const isOpen = item?.classList.toggle('is-open') ?? false;
        button.setAttribute('aria-expanded', String(isOpen));
      });
    });

    const vmSteps = document.querySelectorAll('[data-vm-step]');
    const vmCards = document.querySelectorAll('[data-vm-card]');

    if (vmSteps.length && vmCards.length && 'IntersectionObserver' in window) {
      const setActiveCard = (id) => {
        vmCards.forEach((card) => {
          card.classList.toggle('is-active', card.getAttribute('data-vm-card') === id);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) setActiveCard(entry.target.getAttribute('data-vm-step'));
          });
        },
        { rootMargin: '-35% 0px -45% 0px' },
      );

      vmSteps.forEach((step) => observer.observe(step));
    }
  </script>
</Base>

<style>
  /* ================= STORY ================= */
  .ab-story {
    padding-block: var(--space-2xl);
    row-gap: var(--space-m);
  }

  .ab-story-label {
    grid-column: 1 / 3;
    color: var(--ink);
    padding-top: 0.5rem;
  }

  .ab-story-lead {
    grid-column: 1 / 9;
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    line-height: var(--lh-body);
  }

  .ab-story-body {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    color: var(--ink-soft);
  }

  @media (max-width: 56rem) {
    .ab-story-label,
    .ab-story-lead {
      grid-column: 1 / -1;
    }

    .ab-story-body {
      grid-column: 2 / -1;
    }
  }

  /* ================= VALUES — dark editorial list ================= */
  .ab-values {
    background: var(--ink);
    color: var(--c-bone);
    padding-block: var(--space-2xl);
  }

  .ab-values-inner {
    padding-inline: var(--gutter);
  }

  .ab-values-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    line-height: var(--lh-body);
    letter-spacing: 0;
    color: var(--c-bone);
    margin-bottom: var(--space-xl);
    max-width: 26ch;
  }

  /* Each value is a full-width row: index + name, generous breathing
     room, separated by hairline rules. Names only, per the guidelines. */
  .ab-values-list {
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 16%, transparent);
  }

  .ab-value {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    align-items: baseline;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding-block: clamp(1.75rem, 3.5vw, 3rem);
    border-bottom: 1px solid color-mix(in srgb, var(--c-bone) 16%, transparent);
  }

  .ab-value-n {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    color: var(--accent-soft);
  }

  .ab-value-toggle {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    text-align: left;
  }

  .ab-value-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.5rem, 3.2vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-bone);
    text-wrap: balance;
  }

  .ab-value-toggle:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--c-bone) 60%, transparent);
    outline-offset: 0.35rem;
  }

  .ab-value-desc {
    grid-column: 2;
    max-width: 38rem;
    margin-top: var(--space-s);
    color: color-mix(in srgb, var(--c-bone) 70%, transparent);
    display: none;
    opacity: 0;
    transform: translateY(0.4rem);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .ab-value.is-open .ab-value-desc {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 40rem) {
    .ab-value {
      grid-template-columns: 2.5rem 1fr;
      gap: var(--space-s);
    }

    .ab-value-desc {
      grid-column: 2;
    }
  }

  /* ================= VISION / MISSION ================= */
  .ab-vm {
    background: var(--bg);
    padding: 0 var(--gutter) var(--space-2xl);
  }

  .ab-vm-story {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    min-height: 200vh;
  }

  .ab-vm-stack {
    position: sticky;
    top: 12vh;
    align-self: start;
    height: 76vh;
    display: grid;
    place-items: center;
  }

  .ab-vm-pin {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    isolation: isolate;
  }

  .ab-vm-card {
    grid-area: 1 / 1;
    width: min(100%, 44rem);
    height: min(76vh, 46rem);
    margin: 0;
    background: var(--bg);
    opacity: 0;
    transform: translateY(2rem) scale(0.96);
    transition:
      opacity 700ms var(--ease-out),
      transform 700ms var(--ease-out),
      clip-path 700ms var(--ease-out);
    will-change: opacity, transform, clip-path;
    box-shadow: 0 2rem 5rem rgb(0 0 0 / 0.12);
  }

  .ab-vm-card.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
    z-index: 1;
  }

  .ab-vm-card[data-vm-card='belief']:not(.is-active) {
    opacity: 0.28;
    transform: scale(0.96);
  }

  .ab-vm-card[data-vm-card='work'] {
    z-index: 2;
    transform: translateY(4rem) scale(0.94);
    clip-path: inset(100% 0 0 0);
  }

  .ab-vm-card[data-vm-card='work'].is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
    clip-path: inset(0 0 0 0);
  }

  .ab-vm-card img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ab-vm-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0 clamp(2rem, 5vw, 5rem);
  }

  .ab-vm-step {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
  }

  .ab-vm-step-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .ab-vm-label {
    color: var(--ink-soft);
  }

  .ab-vm-title {
    max-width: 36rem;
    margin: 0 0 var(--space-s);
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 2.6vw, 3rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .ab-vm-step-card p {
    max-width: 32rem;
    color: var(--ink-soft);
  }

  .ab-vm-step-card blockquote {
    max-width: 25rem;
    margin: var(--space-m) 0 0;
    padding-left: var(--space-s);
    border-left: 1px solid var(--accent);
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.4vw, 2.4rem);
    font-style: italic;
    line-height: 1.12;
  }

  @media (max-width: 56rem) {
    .ab-vm {
      padding: 0 0 var(--space-2xl);
    }
    .ab-vm-story {
      grid-template-columns: 1fr;
      gap: 0;
      min-height: auto;
      padding-bottom: 0;
    }
    .ab-vm-stack {
      position: relative;
      top: auto;
      min-height: 60vh;
    }
    .ab-vm-pin {
      position: relative;
      top: auto;
      height: 60vh;
    }
    .ab-vm-card {
      transform: none;
    }
    .ab-vm-copy {
      padding: var(--space-l);
    }
    .ab-vm-step {
      min-height: auto;
      padding-block: var(--space-l);
    }
    .ab-vm-step-card {
      gap: var(--space-s);
    }
  }

  /* ================= STUDIO ================= */
  .ab-studio {
    padding-top: clamp(4rem, 10vw, 8rem);
  }

  .ab-studio-image {
    height: 100svh;
    overflow: hidden;
  }

  .ab-studio-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ab-studio-foot {
    padding-block: var(--space-2xl) 0;
    row-gap: var(--space-m);
  }

  /* Grid-anchored editorial pull-quote (Lora italic) — a hairline rule
     gives it structure instead of floating it loosely in the middle. */
  .ab-studio-quote {
    grid-column: 2 / 11;
    padding-top: var(--space-l);
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    line-height: var(--lh-body);
    color: var(--ink);
    text-wrap: balance;
  }

  .ab-studio-link {
    grid-column: 2 / 6;
  }

  @media (max-width: 56rem) {
    .ab-studio-image {
      height: 100svh;
    }

    .ab-studio-quote,
    .ab-studio-link {
      grid-column: 1 / -1;
    }
  }
</style>


