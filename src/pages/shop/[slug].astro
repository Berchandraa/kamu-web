---
/**
 * Product page — one route per product from src/data/products.ts.
 * Sawdust model: gallery left, calm info column right, marketplace
 * link-out (no cart yet, per the brand guide), related row below.
 *
 * Swap slots: main = product-NN.jpg (shared with the catalog),
 * alternates = product-NN-alt-01.jpg / -alt-02.jpg.
 */
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';
import { products, categories } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => {
    const related = [
      ...products.filter(
        (p) => p.category === product.category && p.slug !== product.slug
      ),
      ...products.filter((p) => p.category !== product.category),
    ].slice(0, 4);
    return { params: { slug: product.slug }, props: { product, related } };
  });
}

const { product: p, related } = Astro.props;
const catLabel = categories.find((c) => c.slug === p.category)?.label;
const base = p.file.replace('.jpg', '');
const shots = [
  { file: p.file, demo: p.demo },
  { file: `${base}-alt-01.jpg`, demo: p.alts[0] },
  { file: `${base}-alt-02.jpg`, demo: p.alts[1] },
];

// short intro = first sentence; full desc lives in the accordion
const firstSentence = p.desc.split(/(?<=\.)\s/)[0];

const care: Record<string, string> = {
  'dining-table':
    'Wipe with a soft, damp cloth and dry immediately. Re-oil the surface once a year with a natural hard-wax oil. Keep out of prolonged direct sun; use trivets under hot dishes.',
  'dining-chair':
    'Dust with a dry cloth. Tighten joinery gently once a year. For woven seats, vacuum on low; for upholstery, blot spills immediately with an absorbent cloth.',
  'lounge-chair':
    'Vacuum upholstery on low monthly and blot spills immediately. Rotate loose cushions regularly. Keep woven and timber parts out of prolonged direct sun.',
  cabinets:
    'Wipe with a soft, damp cloth along the grain. Re-oil annually. Brass hardware will patina naturally — polish only if you prefer it bright.',
  pendants:
    'Dust with a dry cloth with the power off. Maximum 8W LED (E27). Have installation carried out by a qualified electrician.',
};

const accordion = [
  {
    key: 'Description',
    body: `${p.desc} Made to order in our Bali workshop and finished by hand — small variations in grain and weave are part of the piece.`,
  },
  { key: 'Dimensions', body: p.dims },
  { key: 'Materials', body: p.materials },
  {
    key: 'Designers',
    body: 'Designed by the KAMU studio in Umalas, Bali, and produced in partnership with family workshops across the island.',
  },
  { key: 'Product Care', body: care[p.category] },
];
---

<Base title={p.name} description={`${p.name} — ${p.desc}`}>
  <!-- ============ PRODUCT ============ -->
  <section class="pd grid-12">
    <!-- gallery -->
    <div class="pd-gallery">
      <div class="media frame-3x4 pd-main" data-reveal="media">
        <img
          id="pd-main-img"
          src={shots[0].demo}
          alt={p.name}
        />
      </div>

      <div class="pd-thumbs" data-reveal data-reveal-delay="0.2">
        {
          shots.map((s, i) => (
            <button
              class={`pd-thumb ${i === 0 ? 'is-active' : ''}`}
              data-file={s.file}
              aria-label={`View image ${i + 1}`}
            >
              <span class="media frame-1x1">
                <img
                  src={s.demo}
                  alt=""
                  loading="lazy"
                />
              </span>
            </button>
          ))
        }
      </div>
    </div>

    <!-- info -->
    <div class="pd-info">
      <nav class="label pd-crumb duo" data-reveal aria-label="Breadcrumb">
        <a href="/shop/">Shop</a>
        <span class="duo-sub">{catLabel}</span>
      </nav>

      <h1 class="pd-name" data-reveal="line">{p.name}</h1>
      <p class="pd-price" data-reveal data-reveal-delay="0.1">{p.price}</p>

      <p class="pd-desc" data-reveal data-reveal-delay="0.15">{firstSentence}</p>

      <button
        class="pd-add"
        id="pd-add"
        data-id={p.slug}
        data-name={p.name}
        data-amount={p.amount}
        data-image={p.demo}
        data-fallback={p.demo}
        data-reveal
        data-reveal-delay="0.2"
      >
        <span class="pd-add-label">Add to Bag</span>
        <span class="pd-add-added" aria-hidden="true">Added</span>
      </button>

      <div class="pd-acc" data-reveal data-reveal-delay="0.25">
        {
          accordion.map((a) => (
            <details class="pd-acc-item">
              <summary class="pd-acc-head">
                <span class="pd-acc-key">{a.key}</span>
                <span class="pd-acc-icon" aria-hidden="true">+</span>
              </summary>
              <div class="pd-acc-body">
                <p>{a.body}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ RELATED ============ -->
  <section class="pd-related">
    <header class="pd-related-head grid-12">
      <h2 class="h2 pd-related-title" data-reveal="line">You may also like</h2>
      <a href="/shop/" class="text-link label pd-related-all" data-reveal>
        Shop all pieces
      </a>
    </header>

    <div class="pd-related-row">
      {
        related.map((r, i) => (
          <a
            href={`/shop/${r.slug}/`}
            class="pd-card"
            data-reveal
            data-reveal-delay={String(i * 0.08)}
          >
            <Placeholder name={r.file} ratio="3x4" demo={r.demo} alt={r.name} />
            <div class="pd-card-caption">
              <h3 class="pd-card-name">{r.name}</h3>
              <p class="caption">{r.price}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Base>

<style>
  /* ================= PRODUCT ================= */
  .pd {
    padding-top: calc(var(--nav-h) + var(--space-l));
    row-gap: var(--space-l);
  }

  .pd-gallery {
    grid-column: 1 / 8;
  }

  .pd-main :global(img) {
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .pd-main.media,
  .pd-thumb .media {
    background: var(--bg-alt);
  }

  .pd-thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .pd-thumb {
    width: clamp(4rem, 7vw, 6rem);
    opacity: 0.55;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .pd-thumb .media {
    display: block;
  }

  .pd-thumb.is-active,
  .pd-thumb:hover {
    opacity: 1;
  }

  /* ----- info column ----- */
  .pd-info {
    grid-column: 9 / 13;
    align-self: start;
    position: sticky;
    top: calc(var(--nav-h) + var(--space-s));
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding-top: var(--space-m);
  }

  .pd-crumb {
    color: var(--ink);
  }

  .pd-crumb a {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .pd-crumb a:hover {
    color: var(--accent);
  }

  /* product name in Lora serif, large */
  .pd-name {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 3.4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .pd-price {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink);
  }

  .pd-desc {
    color: var(--ink-soft);
    max-width: 30rem;
  }

  /* ----- add to bag ----- */
  .pd-add {
    position: relative;
    width: 100%;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    padding: 1.3em;
    background: var(--ink);
    color: var(--c-bone);
    margin-top: var(--space-2xs);
    transition: background-color var(--dur-base) var(--ease-out);
  }

  .pd-add:hover {
    background: var(--accent);
  }

  .pd-add-added {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: var(--accent);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .pd-add.is-added .pd-add-added {
    opacity: 1;
  }

  /* ----- accordion ----- */
  .pd-acc {
    margin-top: var(--space-s);
  }

  .pd-acc-item {
    border-top: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .pd-acc-item:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .pd-acc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    padding-block: 1.1rem;
    cursor: pointer;
    list-style: none;
  }

  .pd-acc-head::-webkit-details-marker {
    display: none;
  }

  .pd-acc-key {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .pd-acc-head:hover .pd-acc-key {
    color: var(--accent);
  }

  .pd-acc-icon {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.125rem;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .pd-acc-item[open] .pd-acc-icon {
    transform: rotate(45deg);
  }

  .pd-acc-body {
    padding-bottom: var(--space-s);
    color: var(--ink-soft);
    font-size: 0.9375rem;
    max-width: 30rem;
  }

  @media (max-width: 64rem) {
    .pd-gallery {
      grid-column: 1 / -1;
    }

    .pd-info {
      grid-column: 1 / -1;
      position: static;
      padding-top: 0;
    }
  }

  /* ================= RELATED ================= */
  .pd-related {
    padding-top: var(--space-2xl);
  }

  .pd-related-head {
    align-items: end;
    margin-bottom: var(--space-l);
  }

  .pd-related-title {
    grid-column: 1 / 8;
  }

  .pd-related-all {
    grid-column: 10 / 13;
    justify-self: end;
  }

  /* Sawdust horizontal row — snaps, peeks on smaller screens */
  .pd-related-row {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2.5rem);
    overflow-x: auto;
    padding-inline: var(--gutter);
    padding-bottom: var(--space-s);
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }

  .pd-related-row::-webkit-scrollbar {
    display: none;
  }

  .pd-card {
    flex: 0 0 clamp(14rem, 22vw, 20rem);
    scroll-snap-align: start;
  }

  .pd-card :global(.media) {
    background: var(--bg-alt);
  }

  .pd-card :global(img) {
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .pd-card:hover :global(img) {
    transform: scale(1.04);
  }

  .pd-card-caption {
    text-align: center;
    padding-top: var(--space-s);
  }

  .pd-card-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  @media (max-width: 56rem) {
    .pd-related-title,
    .pd-related-all {
      grid-column: 1 / -1;
      justify-self: start;
    }

    .pd-related-all {
      margin-top: var(--space-s);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { cart, openCart } from '../../scripts/cart';

  // Add to bag → cart state + drawer
  const addBtn = document.getElementById('pd-add');
  addBtn?.addEventListener('click', () => {
    const d = addBtn.dataset;
    cart.add({
      id: d.id!,
      name: d.name!,
      amount: Number(d.amount),
      image: d.image!,
      fallback: d.fallback!,
    });
    addBtn.classList.add('is-added');
    setTimeout(() => {
      addBtn.classList.remove('is-added');
      openCart();
    }, 650);
  });

  // Thumbnail → main image swap, gentle crossfade
  const main = document.getElementById('pd-main-img') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.pd-thumb');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!main) return;
      const img = btn.querySelector('img');
      if (!img) return;

      thumbs.forEach((b) => b.classList.toggle('is-active', b === btn));

      const swap = () => {
        // use the thumb's resolved src so the demo fallback carries over
        main.src = img.currentSrc || img.src;
      };

      if (reduced) {
        swap();
      } else {
        gsap.to(main, {
          opacity: 0,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: () => {
            swap();
            gsap.to(main, { opacity: 1, duration: 0.45, ease: 'power2.out' });
          },
        });
      }
    });
  });
</script>
