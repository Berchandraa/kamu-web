---
/**
 * Shop — product catalog.
 * Sawdust-clean but contemporary: pill filters with counts,
 * live result counter, ruled caption rows, quiet hover states.
 * Uniform grid stays (the orderly counterpoint to Projects).
 */
import Base from '../../layouts/Base.astro';
import Placeholder from '../../components/Placeholder.astro';
import { products, categories } from '../../data/products';

const countFor = (slug: string) =>
  products.filter((p) => p.category === slug).length;

const labelFor = (slug: string) =>
  categories.find((c) => c.slug === slug)?.label ?? '';
---

<Base
  title="Shop"
  description="Furniture and lighting by KAMU Concepts — handcrafted pieces for slow living, made in Bali."
>
  <!-- ============ HEADER ============ -->
  <header class="sh-head grid-12">
    <p class="label sh-eyebrow" data-reveal>
      <span class="duo"><span>by KAMU</span><span class="duo-sub">The Collection</span></span>
    </p>
    <h1 class="display sh-title" data-reveal="line">Shop</h1>
    <p class="sh-intro" data-reveal data-reveal-delay="0.15">
      Handcrafted furniture and lighting, made in Bali. Designed slowly,
      built to last.
    </p>
  </header>

  <!-- ============ FILTERS ============ -->
  <div class="sh-bar" data-reveal>
    <nav class="sh-filters" aria-label="Product categories">
      <button class="sh-filter is-active" data-filter="all" aria-pressed="true">
        All<span class="sh-filter-n">{products.length}</span>
      </button>
      {
        categories.map((c) => (
          <button class="sh-filter" data-filter={c.slug} aria-pressed="false">
            {c.label}<span class="sh-filter-n">{countFor(c.slug)}</span>
          </button>
        ))
      }
    </nav>
    <p class="label sh-showing">
      <span class="duo">
        <span>Showing</span>
        <span class="duo-num" id="sh-count">{products.length}</span>
      </span>
    </p>
  </div>

  <!-- ============ GRID ============ -->
  <section class="sh-grid" id="sh-grid">
    {
      products.map((p, i) => (
        <a
          href={`/shop/${p.slug}/`}
          class="sh-card"
          data-category={p.category}
          data-reveal
          data-reveal-delay={String((i % 3) * 0.1)}
        >
          <div class="sh-media">
            <Placeholder name={p.file} ratio="3x4" demo={p.demo} alt={p.name} />
            <span class="sh-view label" aria-hidden="true">View Piece</span>
          </div>
          <div class="sh-caption">
            <div class="sh-caption-main">
              <h2 class="sh-name">{p.name}</h2>
              <p class="label sh-cat">{labelFor(p.category)}</p>
            </div>
            <p class="sh-price">{p.price}</p>
          </div>
        </a>
      ))
    }
  </section>
</Base>

<style>
  /* ================= HEADER ================= */
  .sh-head {
    padding-top: calc(var(--nav-h) + var(--space-xl));
    padding-bottom: var(--space-l);
    row-gap: var(--space-s);
  }

  .sh-eyebrow {
    grid-column: 1 / 5;
    grid-row: 1;
    color: var(--accent);
  }

  .sh-title {
    grid-column: 1 / 8;
    grid-row: 2;
    text-transform: uppercase;
  }

  .sh-intro {
    grid-column: 9 / 13;
    grid-row: 2;
    align-self: end;
    color: var(--ink);
    opacity: 0.78;
    max-width: 24rem;
  }

  @media (max-width: 56rem) {
    .sh-eyebrow,
    .sh-title,
    .sh-intro {
      grid-column: 1 / -1;
    }

    .sh-intro {
      grid-row: 3;
      margin-top: var(--space-s);
    }
  }

  /* ================= FILTER BAR ================= */
  .sh-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding-inline: var(--gutter);
    padding-block: var(--space-s) var(--space-l);
  }

  .sh-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  /* pill chips — fully legible, active state unmistakable */
  .sh-filter {
    display: inline-flex;
    align-items: baseline;
    gap: 0.625em;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 0.8em 1.5em;
    border: 1px solid color-mix(in srgb, var(--ink) 35%, transparent);
    border-radius: 999px;
    transition:
      background-color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .sh-filter-n {
    font-family: var(--font-serif);
    font-size: 0.85em;
    letter-spacing: 0;
    opacity: 0.55;
  }

  .sh-filter:hover {
    border-color: var(--ink);
  }

  .sh-filter.is-active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--c-bone);
  }

  .sh-showing {
    color: var(--ink);
    white-space: nowrap;
  }

  @media (max-width: 56rem) {
    .sh-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-s);
    }
  }

  /* ================= GRID ================= */
  .sh-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--space-m);
    row-gap: var(--space-xl);
    padding-inline: var(--gutter);
  }

  .sh-card[hidden] {
    display: none;
  }

  .sh-media {
    position: relative;
  }

  .sh-card :global(.media) {
    background: var(--bg-alt);
  }

  .sh-card :global(img) {
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .sh-card:hover :global(img) {
    transform: scale(1.04);
  }

  /* hover affordance — quiet pill rises in the frame */
  .sh-view {
    position: absolute;
    right: 0.875rem;
    bottom: 0.875rem;
    z-index: 2;
    padding: 0.7em 1.3em;
    background: var(--c-bone);
    color: var(--ink);
    border-radius: 999px;
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
    pointer-events: none;
  }

  .sh-card:hover .sh-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* ruled caption row: name + category left, price right */
  .sh-caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    border-top: 1px solid color-mix(in srgb, var(--ink) 22%, transparent);
    margin-top: 1rem;
    padding-top: 0.875rem;
  }

  .sh-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .sh-card:hover .sh-name {
    color: var(--accent);
  }

  .sh-cat {
    margin-top: 0.5rem;
    color: color-mix(in srgb, var(--ink) 55%, transparent);
  }

  .sh-price {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--ink);
    white-space: nowrap;
  }

  @media (max-width: 64rem) {
    .sh-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 40rem) {
    .sh-grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-l);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  // Category filter — calm fade out, re-stagger in, live count
  const filters = document.querySelectorAll<HTMLButtonElement>('.sh-filter');
  const cards = document.querySelectorAll<HTMLElement>('.sh-card');
  const count = document.getElementById('sh-count');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.filter;

      filters.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', String(active));
      });

      const apply = () => {
        const shown: HTMLElement[] = [];
        cards.forEach((card) => {
          const show = target === 'all' || card.dataset.category === target;
          card.hidden = !show;
          if (show) shown.push(card);
        });
        if (count) count.textContent = String(shown.length);
        if (!reduced) {
          gsap.fromTo(
            shown,
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.8, stagger: 0.06, ease: 'power3.out', overwrite: true }
          );
        } else {
          shown.forEach((c) => ((c.style.opacity = '1'), (c.style.transform = 'none')));
        }
      };

      if (!reduced) {
        gsap.to(cards, {
          opacity: 0,
          duration: 0.3,
          ease: 'power2.in',
          overwrite: true,
          onComplete: apply,
        });
      } else {
        apply();
      }
    });
  });
</script>
