---
/**
 * Projects — portfolio index (Yodezeen model).
 * An "All Projects" header over a tight, image-led masonry grid:
 * varied heights, small consistent gaps, every slot a real interior.
 * A calm tracked-out filter bar scopes the grid by project type.
 * Captions stay minimal — name + location, clean separator system.
 */
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects';
import CTA from '../../components/CTA.astro';

// Filter bar — built from the real project types in the data
const filters = [
  { key: 'all', label: 'All' },
  { key: 'residential', label: 'Residential' },
  { key: 'hospitality', label: 'Hospitality' },
];

---

<Base
  title="Projects"
  description="Selected interiors by KAMU Concepts — hospitality, residential and workspace projects across Bali."
>
  <!-- ============ HEADER ============ -->
  <header class="pj-head">
    <p class="label pj-eyebrow" data-reveal>
      <span class="duo"><span>Interior Design</span><span class="duo-sub">Architecture</span></span>
    </p>
    <h1 class="pj-title" data-reveal="line">All Projects</h1>
    <p class="pj-intro" data-reveal data-reveal-delay="0.1">
      A growing portfolio of hospitality, residential and workspace interiors
      across Bali. Each begins with how a space should feel.
    </p>

    <!-- ============ FILTER BAR ============ -->
    <div class="pj-filters" role="tablist" aria-label="Filter projects by type" data-reveal data-reveal-delay="0.15">
      {
        filters.map((f, i) => (
          <button
            class={`pj-filter${i === 0 ? ' is-active' : ''}`}
            data-filter={f.key}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </header>

  <!-- ============ MASONRY GRID ============ -->
  <div class="pj-grid" id="pj-grid">
    {
      projects.map((p) => (
        <a
          href={`/projects/${p.slug}/`}
          class="pj-card"
          data-type={p.type.toLowerCase()}
          data-reveal="media"
        >
          <div class="media frame-2x3 pj-media">
            <img src={p.gallery[1] ?? p.demo} alt={p.name} loading="lazy" />
            <div class="pj-hover-content">
              <h2 class="pj-name">{p.name}</h2>
              <p class="caption pj-loc duo">
                <span>{p.location}</span><span class="duo-sub">{p.type}</span>
              </p>
            </div>
          </div>
        </a>
      ))
    }
  </div>

  <p class="pj-empty caption" id="pj-empty" hidden>No projects in this category yet.</p>

  <CTA />
</Base>

<style>
  /* ================= HEADER ================= */
  .pj-head {
    padding-inline: var(--gutter);
    padding-top: calc(var(--nav-h) + var(--space-2xl));
    padding-bottom: var(--space-l);
  }

  .pj-eyebrow {
    color: var(--ink);
    margin-bottom: var(--space-s);
  }

  .pj-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
    text-transform: uppercase;
  }

  .pj-intro {
    max-width: 32rem;
    margin-top: var(--space-m);
    color: var(--ink-soft);
  }

  /* ================= FILTER BAR ================= */
  .pj-filters {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-top: var(--space-l);
    padding-bottom: var(--space-s);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }

  .pj-filter {
    position: relative;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-bottom: 0.4rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .pj-filter::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .pj-filter:hover {
    color: var(--ink);
  }

  .pj-filter.is-active {
    color: var(--ink);
  }

  .pj-filter.is-active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ================= PROJECT GRID ================= */
  .pj-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    padding-inline: var(--gutter);
    margin-top: var(--space-l);
  }

  .pj-card {
    display: block;
  }

  .pj-card.is-hidden {
    display: none;
  }

  .pj-media {
    position: relative;
    background: var(--bg-alt);
    overflow: hidden;
    border-radius: 0;
    transition: border-radius var(--dur-base) var(--ease-out);
  }

  .pj-card:hover .pj-media,
  .pj-card:focus-visible .pj-media {
    border-radius: 999px 999px 0 0;
  }

  .pj-media::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgb(0 0 0 / 0.65);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-base) var(--ease-out);
  }

  .pj-card:hover .pj-media::after,
  .pj-card:focus-visible .pj-media::after {
    opacity: 1;
  }

  /* ----- hover content ----- */
  .pj-hover-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    gap: var(--space-xs);
    padding: var(--space-m);
    padding-bottom: var(--space-l);
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
    pointer-events: none;
  }

  .pj-card:hover .pj-hover-content,
  .pj-card:focus-visible .pj-hover-content {
    opacity: 1;
    transform: translateY(0);
  }

  .pj-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.5rem);
    letter-spacing: 0.02em;
    color: var(--c-bone);
  }

  .pj-loc {
    color: color-mix(in srgb, var(--c-bone) 85%, transparent);
    white-space: nowrap;
  }

  .pj-empty {
    padding: var(--space-2xl) var(--gutter);
    text-align: center;
  }

  /* ================= RESPONSIVE ================= */
  @media (max-width: 64rem) {
    .pj-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .pj-grid {
      grid-template-columns: 1fr;
    }

    .pj-cap {
      padding-bottom: var(--space-l);
    }
  }
</style>

<style is:global>
  /* Projects index has a bone background from the very top (no dark hero),
     so pin the navbar to high-contrast ink and bring the links + CTA to
     full strength — they must read clearly over bone, never faint. */
  .nav:not(.is-condensed) {
    color: var(--ink);
  }

  .nav:not(.is-condensed) .nav-link {
    opacity: 1;
  }

  .nav:not(.is-condensed) .nav-cta {
    border-color: color-mix(in srgb, var(--ink) 78%, transparent);
  }
</style>

<script>
  const grid = document.getElementById('pj-grid');
  const empty = document.getElementById('pj-empty');
  const filters = document.querySelectorAll<HTMLButtonElement>('.pj-filter');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.pj-card'));

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.filter || 'all';

      filters.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });

      let shown = 0;
      cards.forEach((card) => {
        const match = key === 'all' || card.dataset.type === key;
        card.classList.toggle('is-hidden', !match);
        // ensure any not-yet-revealed cards are visible once filtered in
        if (match) {
          card.style.opacity = '1';
          shown++;
        }
      });

      if (empty) empty.toggleAttribute('hidden', shown !== 0);
    });
  });
</script>
