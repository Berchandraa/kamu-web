---
/**
 * Projects — portfolio index (Yodezeen model).
 * An "All Projects" header over a tight, image-led masonry grid:
 * varied heights, small consistent gaps, every slot a real interior.
 * A calm tracked-out filter bar scopes the grid by project type.
 * Captions stay minimal — name + location, clean separator system.
 */
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects';
import CTA from '../../components/CTA.astro';

// Filter bar — built from the real project types in the data
const filters = [
  { key: 'all', label: 'All' },
  { key: 'residential', label: 'Residential' },
  { key: 'hospitality', label: 'Hospitality' },
  { key: 'workspace', label: 'Workspace' },
];

// Aspect pattern keeps the masonry lively (tall / wide / square mix)
const ratios = ['3x4', '4x3', '1x1', '3x4', '4x3', '4x3', '3x4'];
const ratioFor = (i: number) => ratios[i % ratios.length];
---

<Base
  title="Projects"
  description="Selected interiors by KAMU Concepts — hospitality, residential and workspace projects across Bali."
>
  <!-- ============ HEADER ============ -->
  <header class="pj-head">
    <p class="label pj-eyebrow" data-reveal>
      <span class="duo"><span>Interior Design</span><span class="duo-sub">Architecture</span></span>
    </p>
    <h1 class="pj-title" data-reveal="line">All Projects</h1>
    <p class="pj-intro" data-reveal data-reveal-delay="0.1">
      A growing portfolio of hospitality, residential and workspace interiors
      across Bali. Each begins with how a space should feel.
    </p>

    <!-- ============ FILTER BAR ============ -->
    <div class="pj-filters" role="tablist" aria-label="Filter projects by type" data-reveal data-reveal-delay="0.15">
      {
        filters.map((f, i) => (
          <button
            class={`pj-filter${i === 0 ? ' is-active' : ''}`}
            data-filter={f.key}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </header>

  <!-- ============ MASONRY GRID ============ -->
  <div class="pj-grid" id="pj-grid">
    {
      projects.map((p, i) => (
        <a
          href={`/projects/${p.slug}/`}
          class="pj-card"
          data-type={p.type.toLowerCase()}
          data-reveal="media"
        >
          <div class={`media frame-${ratioFor(i)} pj-media`}>
            <img src={p.demo} alt={p.name} loading="lazy" />
            <span class="pj-logo-reveal" aria-hidden="true">
            </span>
          </div>
          <div class="pj-cap">
            <h2 class="pj-name">{p.name}</h2>
            <p class="caption pj-loc duo">
              <span>{p.location}</span><span class="duo-sub">{p.type}</span>
            </p>
          </div>
        </a>
      ))
    }
  </div>

  <p class="pj-empty caption" id="pj-empty" hidden>No projects in this category yet.</p>

  <CTA />
</Base>

<style>
  /* ================= HEADER ================= */
  .pj-head {
    padding-inline: var(--gutter);
    padding-top: calc(var(--nav-h) + var(--space-2xl));
    padding-bottom: var(--space-l);
  }

  .pj-eyebrow {
    color: var(--ink);
    margin-bottom: var(--space-s);
  }

  .pj-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
    text-transform: uppercase;
  }

  .pj-intro {
    max-width: 32rem;
    margin-top: var(--space-m);
    color: var(--ink-soft);
  }

  /* ================= FILTER BAR ================= */
  .pj-filters {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-top: var(--space-l);
    padding-bottom: var(--space-s);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }

  .pj-filter {
    position: relative;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-bottom: 0.4rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .pj-filter::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .pj-filter:hover {
    color: var(--ink);
  }

  .pj-filter.is-active {
    color: var(--ink);
  }

  .pj-filter.is-active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ================= MASONRY GRID ================= */
  .pj-grid {
    columns: 3;
    column-gap: 0.5rem;
    padding-inline: var(--gutter);
    margin-top: var(--space-l);
  }

  .pj-card {
    display: block;
    break-inside: avoid;
    margin-bottom: 0.5rem;
  }

  .pj-card.is-hidden {
    display: none;
  }

  .pj-media {
    background: var(--bg-alt);
  }

  .pj-media img {
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .pj-card:hover .pj-media img {
    transform: scale(1.05);
  }

  .pj-logo-reveal {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    background: rgb(0 0 0 / 0.22);
    transform: scale(0.98);
    transform-origin: center;
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .pj-logo-reveal::before {
    content: '';
    width: clamp(5.5rem, 12vw, 9rem);
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--c-bone) 70%, transparent);
    border-radius: 999px;
    background: rgb(0 0 0 / 0.18);
    backdrop-filter: blur(8px);
  }

  .pj-logo-reveal::after {
    content: '';
    position: absolute;
    width: clamp(2.8rem, 6vw, 4.6rem);
    aspect-ratio: 1;
    background: var(--c-bone);
    -webkit-mask: url('/assets/asset-1.svg') no-repeat center / 62%;
    mask: url('/assets/asset-1.svg') no-repeat center / 62%;
  }

  .pj-card:hover .pj-logo-reveal,
  .pj-card:focus-visible .pj-logo-reveal {
    opacity: 1;
    transform: scale(1);
  }

  /* ----- minimal caption: name + location ----- */
  .pj-cap {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    padding: 0.85rem 0.1rem var(--space-m);
  }

  .pj-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(0.95rem, 1.4vw, 1.125rem);
    letter-spacing: 0.01em;
  }

  .pj-loc {
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .pj-empty {
    padding: var(--space-2xl) var(--gutter);
    text-align: center;
  }

  /* ================= RESPONSIVE ================= */
  @media (max-width: 64rem) {
    .pj-grid {
      columns: 2;
    }
  }

  @media (max-width: 40rem) {
    .pj-grid {
      columns: 1;
    }

    .pj-cap {
      padding-bottom: var(--space-l);
    }
  }
</style>

<style is:global>
  /* Projects index has a bone background from the very top (no dark hero),
     so pin the navbar to high-contrast ink and bring the links + CTA to
     full strength — they must read clearly over bone, never faint. */
  .nav:not(.is-condensed) {
    color: var(--ink);
  }

  .nav:not(.is-condensed) .nav-link,
  .nav:not(.is-condensed) .nav-bag {
    opacity: 1;
  }

  .nav:not(.is-condensed) .nav-cta {
    border-color: color-mix(in srgb, var(--ink) 78%, transparent);
  }
</style>

<script>
  const grid = document.getElementById('pj-grid');
  const empty = document.getElementById('pj-empty');
  const filters = document.querySelectorAll<HTMLButtonElement>('.pj-filter');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.pj-card'));

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.filter || 'all';

      filters.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });

      let shown = 0;
      cards.forEach((card) => {
        const match = key === 'all' || card.dataset.type === key;
        card.classList.toggle('is-hidden', !match);
        // ensure any not-yet-revealed cards are visible once filtered in
        if (match) {
          card.style.opacity = '1';
          shown++;
        }
      });

      if (empty) empty.toggleAttribute('hidden', shown !== 0);
    });
  });
</script>
