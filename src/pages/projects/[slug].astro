---
/**
 * Project Details â€” one route per project, generated from
 * src/data/projects.ts. Bureau model: image-led, asymmetric
 * gallery rhythm, generous whitespace, slow motion.
 *
 * Swap slots: hero = project-NN.jpg (same file as the index),
 * gallery = project-NN-detail-01.jpg â€¦ -06.jpg.
 */
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project, i) => ({
    params: { slug: project.slug },
    props: { project, next: projects[(i + 1) % projects.length] },
  }));
}

const { project: p, next } = Astro.props;
---

<Base title={p.name} description={`${p.name} â€” ${p.meta}. ${p.intro}`}>
  <!-- ============ HERO â€” full-bleed, caption bottom-left ============ -->
  <section class="hero" data-nav-invert>
    <div class="hero-media">
      <img
        src={p.demo}
        alt={p.name}
      />
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="hero-caption">
      <p class="label hero-n">
        <span class="duo"><span>Project</span><span class="duo-num">{p.n}</span></span>
      </p>
      <h1 class="display hero-name">{p.name}</h1>
      <p class="label hero-meta duo"><span>{p.location}</span><span class="duo-sub">{p.type}</span></p>
    </div>
  </section>

  <!-- ============ INTRO â€” concept, materials, approach ============ -->
  <section class="intro grid-12">
    <p class="label intro-label" data-reveal>Concept</p>
    <p class="sub intro-lead" data-reveal="line">{p.intro}</p>
    <p class="intro-body" data-reveal data-reveal-delay="0.15">{p.body}</p>
    {p.logo && (
      <img class="intro-logo" src={p.logo} alt={`${p.name} logo`} loading="lazy" data-reveal />
    )}
  </section>

  <!-- ============ META ROW ============ -->
  <section class="meta grid-12" data-reveal>
    <div class="meta-item">
      <p class="label meta-key">Location</p>
      <p class="meta-val">{p.location}</p>
    </div>
    <div class="meta-item">
      <p class="label meta-key">Year</p>
      <p class="meta-val">{p.year}</p>
    </div>
    <div class="meta-item">
      <p class="label meta-key">Type</p>
      <p class="meta-val">{p.type}</p>
    </div>
    <div class="meta-item">
      <p class="label meta-key">Scope</p>
      <p class="meta-val">{p.scope}</p>
    </div>
  </section>

  <!-- ============ GALLERY â€” Bureau rhythm ============ -->
  <section class="gallery">
    {p.gallery.slice(0, 2).map((image, i) => (
      <div class="g-long" data-reveal="media">
        <img src={image} alt={i === 0 ? p.name : `${p.name} detail`} loading="lazy" />
      </div>
    ))}

    <!-- Editorial beat: the written middle of the gallery -->
    <div class="story grid-12">
      <p class="label story-label" data-reveal>Approach</p>

      <h2 class="h2 story-title" data-reveal="line">{p.storyTitle}</h2>

      <div class="story-body" data-reveal data-reveal-delay="0.15">
        <p>{p.story[0]}</p>
        <p>{p.story[1]}</p>
      </div>

      <div class="story-materials" data-reveal data-reveal-delay="0.25">
        <p class="label story-materials-key">Materials</p>
        <ul class="story-materials-list">
          {p.materials.map((m) => <li>{m}</li>)}
        </ul>
      </div>

      <blockquote class="story-quote" data-reveal="line">
        <p class="quote">&ldquo;{p.quote}&rdquo;</p>
      </blockquote>
    </div>

    {p.gallery.slice(2).map((image) => (
      <div class="g-long" data-reveal="media">
        <img src={image} alt={`${p.name} detail`} loading="lazy" />
      </div>
    ))}
  </section>

  <!-- ============ NEXT PROJECT ============ -->
  <a href={`/projects/${next.slug}/`} class="next" data-parallax>
    <img
      src={next.demo}
      alt={next.name}
    />
    <div class="next-scrim" aria-hidden="true"></div>
    <div class="next-text">
      <p class="label next-label" data-reveal>Next Project</p>
      <p class="display next-name" data-reveal="line">
        {next.name}
        <svg class="next-arrow" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h13m-5-5 5 5-5 5" />
        </svg>
      </p>
      <p class="label next-meta duo" data-reveal data-reveal-delay="0.15">
        <span>{next.location}</span><span class="duo-sub">{next.type}</span>
      </p>
    </div>
  </a>
</Base>

<style>
  /* ================= HERO ================= */
  .hero {
    position: relative;
    height: 100svh;
    overflow: hidden;
    color: var(--c-bone);
  }

  .hero-media,
  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to top,
        color-mix(in srgb, var(--c-black) 60%, transparent) 0%,
        transparent 42%
      ),
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--c-black) 28%, transparent) 0%,
        transparent 20%
      );
  }

  .hero-caption {
    position: absolute;
    z-index: 2;
    left: var(--gutter);
    bottom: clamp(2.5rem, 7vh, 5rem);
  }

  .hero-n {
    color: color-mix(in srgb, var(--c-bone) 75%, transparent);
    margin-bottom: var(--space-s);
  }

  .hero-name {
    max-width: calc(100vw - (var(--gutter) * 2));
    overflow-wrap: break-word;
    text-transform: uppercase;
  }

  .hero-meta {
    margin-top: var(--space-s);
    opacity: 0.8;
  }

  /* ================= INTRO ================= */
  .intro {
    padding-block: var(--space-2xl) var(--space-xl);
    row-gap: var(--space-m);
  }

  .intro-label {
    grid-column: 1 / 3;
    color: var(--ink);
    padding-top: 0.5rem;
  }

  .intro-lead {
    grid-column: 1 / 9;
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.4vw, 2rem);
    line-height: var(--lh-body);
    letter-spacing: var(--ls-none);
  }

  .intro-body {
    grid-column: 1 / 7;
    color: var(--ink-soft);
  }

  .intro-logo {
    grid-column: 9 / 12;
    grid-row: 2 / 4;
    align-self: start;
    justify-self: center;
    width: min(10.5rem, 100%);
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
    opacity: 0.9;
  }

  @media (max-width: 56rem) {
    .intro-label,
    .intro-lead {
      grid-column: 1 / -1;
    }

    .intro-body {
      grid-column: 2 / -1;
    }

    .intro-logo {
      grid-column: 2 / -1;
      grid-row: auto;
      justify-self: start;
      width: 11rem;
    }
  }

  /* ================= META ROW ================= */
  .meta {
    row-gap: var(--space-m);
    padding-bottom: var(--space-xl);
  }

  .meta-item {
    grid-column: span 3;
    border-top: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
    padding-top: 1rem;
  }

  .meta-key {
    color: var(--ink-soft);
    letter-spacing: 0.02em;
    margin-bottom: 0.625rem;
  }

  .meta-val {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 56rem) {
    .meta-item {
      grid-column: span 6;
    }
  }

  /* ================= GALLERY ================= */
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .g-long {
    width: 100%;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .g-long img {
    display: block;
    width: 100%;
    height: min(92svh, 56rem);
    object-fit: cover;
  }

  /* ----- the written middle ----- */
  .story {
    padding-block: var(--space-2xl);
    row-gap: var(--space-m);
  }

  .story-label {
    grid-column: 1 / 3;
    color: var(--ink);
    padding-top: 0.4rem;
  }

  .story-title {
    grid-column: 4 / 11;
    text-wrap: balance;
  }

  .story-body {
    grid-column: 4 / 9;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    color: var(--ink-soft);
  }

  .story-materials {
    grid-column: 10 / 13;
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
    padding-top: var(--space-s);
  }

  .story-materials-key {
    color: var(--ink-soft);
    margin-bottom: 0.875rem;
  }

  .story-materials-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9375rem;
  }

  .story-quote {
    grid-column: 5 / 12;
    margin-top: var(--space-l);
  }

  .story-quote .quote {
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
  }

  @media (max-width: 56rem) {
    .story-label,
    .story-title,
    .story-quote {
      grid-column: 1 / -1;
    }

    .story-body {
      grid-column: 1 / 11;
    }

    .story-materials {
      grid-column: 2 / -1;
    }
  }

  @media (max-width: 56rem) {
    .g-long img {
      height: auto;
      min-height: 60svh;
    }
  }

  /* ================= NEXT PROJECT ================= */
  .next {
    position: relative;
    display: block;
    margin-top: var(--space-2xl);
    height: min(70svh, 44rem);
    overflow: hidden;
    color: var(--c-bone);
  }

  .next img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .next-scrim {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--c-black) 45%, transparent);
    transition: background-color var(--dur-slow) var(--ease-out);
  }

  .next:hover .next-scrim {
    background: color-mix(in srgb, var(--c-black) 30%, transparent);
  }

  .next-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-inline: var(--gutter);
  }

  .next-label {
    color: color-mix(in srgb, var(--c-bone) 75%, transparent);
    margin-bottom: var(--space-s);
  }

  .next-name {
    text-transform: uppercase;
  }

  .next-arrow {
    display: inline-block;
    width: 0.72em !important;
    height: 0.72em !important;
    max-width: none;
    vertical-align: middle;
    margin-left: 0.18em;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .next:hover .next-arrow {
    transform: translateX(0.4em);
  }

  .next-meta {
    margin-top: var(--space-s);
    opacity: 0.8;
  }
</style>
