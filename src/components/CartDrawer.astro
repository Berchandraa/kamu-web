---
/**
 * Cart drawer — slides in from the right, rendered from cart state.
 * Mounted once in Base.astro so it's available on every page.
 * Checkout is a placeholder until the Shopify wiring lands.
 */
---

<div class="bag-scrim" id="bag-scrim" aria-hidden="true"></div>

<aside
  class="bag"
  id="bag"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping bag"
  aria-hidden="true"
>
  <header class="bag-head">
    <p class="label bag-title">
      <span class="duo">
        <span>Your Bag</span>
        <span class="duo-num bag-count" id="bag-count">0</span>
      </span>
    </p>
    <button class="label bag-close" id="bag-close">Close</button>
  </header>

  <div class="bag-lines" id="bag-lines">
    <!-- rendered by script -->
  </div>

  <div class="bag-empty" id="bag-empty" hidden>
    <p class="quote bag-empty-line">Your bag is empty.</p>
    <a href="/shop/" class="text-link label">Browse the collection</a>
  </div>

  <footer class="bag-foot" id="bag-foot">
    <div class="bag-subtotal">
      <span class="label">Subtotal</span>
      <span class="bag-subtotal-val" id="bag-subtotal">Rp 0</span>
    </div>
    <button class="bag-checkout" disabled>Checkout</button>
    <p class="caption bag-note">
      Shipping &amp; taxes calculated at checkout.
      Checkout connects to Shopify at launch.
    </p>
  </footer>
</aside>

<style>
  .bag-scrim {
    position: fixed;
    inset: 0;
    z-index: 96;
    background: color-mix(in srgb, var(--c-black) 40%, transparent);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--dur-base) var(--ease-in-out),
      visibility 0s var(--dur-base);
  }

  html.bag-open .bag-scrim {
    opacity: 1;
    visibility: visible;
    transition:
      opacity var(--dur-base) var(--ease-in-out),
      visibility 0s;
  }

  .bag {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 97;
    width: min(27rem, 100vw);
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--ink);
    transform: translateX(100%);
    visibility: hidden;
    transition:
      transform var(--dur-slow) var(--ease-in-out),
      visibility 0s var(--dur-slow);
  }

  html.bag-open .bag {
    transform: translateX(0);
    visibility: visible;
    transition:
      transform var(--dur-slow) var(--ease-in-out),
      visibility 0s;
  }

  .bag-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-m) var(--space-s) var(--space-s);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
  }

  .bag-close {
    color: var(--ink-soft);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .bag-close:hover {
    color: var(--ink);
  }

  /* ----- lines ----- */
  .bag-lines {
    flex: 1;
    overflow-y: auto;
    padding: 0 var(--space-s);
  }

  .bag-lines :global(.bag-line) {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: var(--space-s);
    padding-block: var(--space-s);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
  }

  .bag-lines :global(.bag-line-media) {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .bag-lines :global(.bag-line-media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bag-lines :global(.bag-line-name) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  .bag-lines :global(.bag-line-price) {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    margin-top: 0.375rem;
  }

  .bag-lines :global(.bag-line-remove) {
    font-family: var(--font-serif);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    margin-top: 0.625rem;
    width: fit-content;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .bag-lines :global(.bag-line-remove:hover) {
    color: var(--accent);
  }

  /* qty stepper */
  .bag-lines :global(.bag-qty) {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    border: 1px solid color-mix(in srgb, var(--ink) 30%, transparent);
    border-radius: 999px;
    padding: 0.3rem 0.875rem;
    align-self: start;
  }

  .bag-lines :global(.bag-qty button) {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1;
    padding: 0.2rem;
    color: var(--ink-soft);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .bag-lines :global(.bag-qty button:hover) {
    color: var(--ink);
  }

  .bag-lines :global(.bag-qty-n) {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    min-width: 1.25em;
    text-align: center;
  }

  /* ----- empty ----- */
  .bag-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-m);
    padding: var(--space-l);
    text-align: center;
  }

  .bag-empty-line {
    color: var(--ink-soft);
  }

  /* ----- footer ----- */
  .bag-foot {
    padding: var(--space-s) var(--space-s) var(--space-m);
    border-top: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
  }

  .bag-subtotal {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-s);
  }

  .bag-subtotal-val {
    font-family: var(--font-serif);
    font-size: 1.125rem;
  }

  .bag-checkout {
    width: 100%;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    padding: 1.2em;
    background: var(--ink);
    color: var(--c-bone);
    border-radius: 999px;
    opacity: 0.45;
    cursor: not-allowed;
  }

  .bag-note {
    margin-top: 0.875rem;
    text-align: center;
  }
</style>

<script>
  import { cart, formatIDR } from '../scripts/cart';

  const root = document.documentElement;
  const drawer = document.getElementById('bag');
  const linesEl = document.getElementById('bag-lines');
  const emptyEl = document.getElementById('bag-empty');
  const footEl = document.getElementById('bag-foot');
  const countEl = document.getElementById('bag-count');
  const subtotalEl = document.getElementById('bag-subtotal');

  const open = () => {
    root.classList.add('bag-open', 'is-locked');
    drawer?.setAttribute('aria-hidden', 'false');
  };

  const close = () => {
    root.classList.remove('bag-open', 'is-locked');
    drawer?.setAttribute('aria-hidden', 'true');
  };

  const render = () => {
    const lines = cart.lines();
    if (countEl) countEl.textContent = String(cart.count());
    if (subtotalEl) subtotalEl.textContent = formatIDR(cart.subtotal());

    const isEmpty = lines.length === 0;
    if (emptyEl) emptyEl.hidden = !isEmpty;
    if (footEl) footEl.hidden = isEmpty;
    if (linesEl) {
      linesEl.hidden = isEmpty;
      linesEl.innerHTML = lines
        .map(
          (l) => `
        <div class="bag-line" data-id="${l.id}">
          <div class="bag-line-media">
            <img src="${l.image}" alt="" onerror="this.onerror=null;this.src='${l.fallback}'" />
          </div>
          <div>
            <p class="bag-line-name">${l.name}</p>
            <p class="bag-line-price">${formatIDR(l.amount)}</p>
            <button class="bag-line-remove" data-remove="${l.id}">Remove</button>
          </div>
          <div class="bag-qty">
            <button data-dec="${l.id}" aria-label="Decrease quantity">&minus;</button>
            <span class="bag-qty-n">${l.qty}</span>
            <button data-inc="${l.id}" aria-label="Increase quantity">+</button>
          </div>
        </div>`
        )
        .join('');
    }
  };

  // qty / remove — event delegation
  linesEl?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const line = (id: string) => cart.lines().find((l) => l.id === id);
    if (t.dataset.inc) cart.setQty(t.dataset.inc, (line(t.dataset.inc)?.qty ?? 0) + 1);
    else if (t.dataset.dec) cart.setQty(t.dataset.dec, (line(t.dataset.dec)?.qty ?? 0) - 1);
    else if (t.dataset.remove) cart.remove(t.dataset.remove);
  });

  document.getElementById('bag-close')?.addEventListener('click', close);
  document.getElementById('bag-scrim')?.addEventListener('click', close);
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });

  window.addEventListener('cart:open', open);
  window.addEventListener('cart:updated', render);
  render();
</script>
