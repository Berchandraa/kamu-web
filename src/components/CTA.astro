---
/**
 * CTA — the site's closing invitation, shared by every page that ends
 * in a prompt to reach out. An atmospheric moment, not flat text:
 * a warm muted interior fills the frame, a Lora-italic invitation is
 * set over a soft scrim, and a single refined pill button carries the
 * one terracotta accent on the whole page. Used consistently site-wide.
 *
 * Default image uses the live KAMU Concepts portfolio assets.
 */
interface Props {
  eyebrow?: string;
  invite?: string;
  note?: string;
  action?: string;
  href?: string;
  image?: string;
}

const {
  eyebrow = 'New Project',
  invite = 'It would be a privilege\nto hear from you.',
  note = 'Every space we make begins with a conversation. Tell us how you want to live, and we’ll take it from there.',
  action = 'Start a conversation',
  href = '/contact/',
  image = '/assets/home/cta-interior.jpg',
} = Astro.props;

const lines = invite.split('\n');
---

<section class="cta">
  <div class="cta-panel">
  <div class="cta-media" data-parallax>
    <img src={image} alt="" loading="lazy" />
  </div>
  <div class="cta-scrim" aria-hidden="true"></div>

  <div class="cta-inner">
    <p class="label cta-eyebrow" data-reveal>
      <span class="duo">
        <span>{eyebrow}</span>
        <span class="duo-sub">KAMU Concepts</span>
      </span>
    </p>

    <h2 class="cta-invite" data-reveal="line">
      {lines.map((l) => <span class="cta-invite-line">{l}</span>)}
    </h2>

    <p class="cta-note" data-reveal data-reveal-delay="0.1">{note}</p>

    <div class="cta-actions" data-reveal data-reveal-delay="0.2">
      <a href={href} class="cta-btn">
        {action}
        <span class="cta-btn-plus" aria-hidden="true">+</span>
      </a>
      <a href="mailto:hello@kamuconcepts.com" class="cta-mail">hello@kamuconcepts.com</a>
    </div>
  </div>
  </div>
</section>

<style>
  /* Generous calm space around the whole moment — the image band is
     inset from every edge, never touching the section above or below. */
  .cta {
    padding: var(--space-2xl) var(--gutter) var(--space-xl);
    margin-top: var(--space-xl);
  }

  .cta-panel {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(32rem, 74vh, 48rem);
    display: flex;
    align-items: flex-end;
    color: var(--c-bone);
  }

  .cta-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .cta-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Warm, calm scrim — dark from the bottom-left where the copy sits */
  .cta-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        to top,
        color-mix(in srgb, var(--c-black) 78%, transparent) 0%,
        color-mix(in srgb, var(--c-black) 30%, transparent) 45%,
        transparent 78%
      ),
      linear-gradient(
        to right,
        color-mix(in srgb, var(--c-black) 42%, transparent) 0%,
        transparent 55%
      );
  }

  .cta-inner {
    width: 100%;
    max-width: 46rem;
    padding: clamp(2.5rem, 5.5vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .cta-eyebrow {
    color: color-mix(in srgb, var(--c-bone) 82%, transparent);
  }

  .cta-invite {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.6vw, 3.75rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .cta-invite-line {
    display: block;
  }

  .cta-note {
    max-width: 32rem;
    color: color-mix(in srgb, var(--c-bone) 80%, transparent);
    line-height: var(--lh-body);
  }

  .cta-actions {
    margin-top: var(--space-s);
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  /* The one terracotta accent on the page: this button's hover */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 1.1em 2.2em;
    border: 1px solid color-mix(in srgb, var(--c-bone) 60%, transparent);
    border-radius: 999px;
    transition:
      background-color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .cta-btn-plus {
    font-size: 1.15em;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .cta-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--c-bone);
  }

  .cta-btn:hover .cta-btn-plus {
    transform: rotate(90deg);
  }

  .cta-mail {
    position: relative;
    font-family: var(--font-serif);
    font-size: var(--fs-caption);
    color: color-mix(in srgb, var(--c-bone) 78%, transparent);
    padding-bottom: 0.3em;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .cta-mail::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .cta-mail:hover {
    color: var(--c-bone);
  }

  .cta-mail:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 56rem) {
    .cta-actions {
      gap: var(--space-s);
    }
  }
</style>
