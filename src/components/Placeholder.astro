---
/**
 * Media frame — aspect-locked.
 *
 * `demo` is the live image (a direct images.unsplash.com URL) and is
 * shown immediately as the src — no flat-colour flash, no 404-first.
 * `name` is recorded on data-swap as the target filename for the real
 * asset; when real files land in /public/assets we point src at them.
 *
 *   <Placeholder name="project-01.jpg" ratio="3x4" demo={…} alt="…" />
 */
interface Props {
  name: string;
  ratio?: '16x9' | '4x3' | '3x4' | '2x3' | '1x1' | '21x9';
  alt?: string;
  demo: string;
  parallax?: boolean;
  eager?: boolean;
  class?: string;
}

const {
  name,
  ratio = '4x3',
  alt = '',
  demo,
  parallax = false,
  eager = false,
  class: className,
} = Astro.props;

const isVideo = /\.(mp4|webm)$/i.test(name);
---

<div
  class={`media frame-${ratio} ph ${className ?? ''}`}
  data-parallax={parallax ? '' : undefined}
  data-swap={name}
>
  {
    isVideo ? (
      <video src={demo} poster={demo} autoplay muted loop playsinline></video>
    ) : (
      <img src={demo} alt={alt} loading={eager ? 'eager' : 'lazy'} />
    )
  }
</div>

<style>
  .ph {
    background: var(--accent-soft);
  }
</style>
