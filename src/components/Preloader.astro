---
/**
 * Preloader — home page only.
 * K symbol fades up on bone, holds, then the curtain lifts.
 * Plays once per browser session (sessionStorage), skipped
 * entirely for prefers-reduced-motion.
 * Fires `kamu:ready` on window when done — hero intro
 * animations should wait for this event.
 */
---

<div class="preloader" id="preloader" aria-hidden="true">
  <div class="preloader-mark">
    <span class="preloader-logo" role="img" aria-label="KAMU Concepts"></span>
  </div>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
  }

  .preloader-mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
  }

  /* Real KAMU CONCEPTS lockup (asset-1.svg), ink fill on bone */
  .preloader-logo {
    display: block;
    width: clamp(9rem, 24vw, 14rem);
    aspect-ratio: 648.07 / 144;
    background-color: var(--ink);
    -webkit-mask: url('/assets/asset-1.svg') no-repeat center / contain;
    mask: url('/assets/asset-1.svg') no-repeat center / contain;
  }
</style>

<script>
  import { gsap } from 'gsap';

  const preloader = document.getElementById('preloader');

  const finish = () => {
    preloader?.remove();
    document.documentElement.classList.remove('is-locked');
    (window as any).__kamuReady = true;
    window.dispatchEvent(new CustomEvent('kamu:ready'));
  };

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ⚠️ DEV MODE: once-per-session lock DISABLED so the preloader plays on
  // every load for review. Re-enable before final deploy by restoring:
  //   const seen = sessionStorage.getItem('kamu-preloader');
  //   …and `sessionStorage.setItem('kamu-preloader', '1')` below.
  const seen = false;

  if (!preloader || reduced || seen) {
    finish();
  } else {
    document.documentElement.classList.add('is-locked');

    const tl = gsap.timeline({ onComplete: finish });

    tl.from('.preloader-logo', {
      y: 22,
      opacity: 0,
      duration: 1.2,
      ease: 'power3.out',
    })
      .to('.preloader-mark', {
        opacity: 0,
        y: -16,
        duration: 0.6,
        ease: 'power2.in',
        delay: 0.6,
      })
      .to(preloader, {
        yPercent: -100,
        duration: 1.1,
        ease: 'power3.inOut',
      });
  }
</script>
