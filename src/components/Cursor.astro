---
/**
 * Cursor — Yodezeen-style custom pointer.
 * A small monogram ring that trails the mouse with an eased lag; over
 * interactive targets (links, buttons, media) it grows and fills
 * faintly. Desktop + fine-pointer only. Falls back to the native
 * cursor for touch devices and prefers-reduced-motion.
 *
 * Uses mix-blend-mode: difference so the cursor stays visible
 * over both the bone and the dark (hero / footer / mist) sections.
 */
---

<div class="cursor" id="cursor" aria-hidden="true">
  <svg class="cursor-mark" viewBox="0 0 135.87 144" focusable="false">
    <path d="M133.91.03c-38.24,1.05-68.93,32.87-68.93,71.97s31.74,72,70.89,72V0C135.21,0,134.56.01,133.91.03Z" />
    <path d="M0,72v72h70.89c0-39.76-31.74-72-70.89-72Z" />
    <path d="M0,72C39.15,72,70.89,39.76,70.89,0H0v72Z" />
  </svg>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 30px;
    height: 30px;
    margin: -15px 0 0 -15px;
    display: grid;
    place-items: center;
    border: 1.5px solid var(--c-bone);
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    mix-blend-mode: difference;
    will-change: transform;
    transition:
      width var(--dur-fast) var(--ease-out),
      height var(--dur-fast) var(--ease-out),
      margin var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out),
      opacity 0.3s var(--ease-out);
  }

  .cursor-mark {
    width: 52%;
    height: 52%;
    fill: var(--c-bone);
    opacity: 0.82;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  /* Over an interactive target: grow + faint fill */
  .cursor.is-active {
    width: 52px;
    height: 52px;
    margin: -26px 0 0 -26px;
    background: color-mix(in srgb, var(--c-bone) 18%, transparent);
  }

  .cursor.is-active .cursor-mark {
    opacity: 1;
    transform: scale(0.92);
  }

  /* Pressed: a small confident contraction */
  .cursor.is-down {
    width: 22px;
    height: 22px;
    margin: -11px 0 0 -11px;
  }

  .cursor.is-down .cursor-mark {
    opacity: 0;
  }

  /* Only ever shown on fine-pointer desktops with motion allowed */
  @media (hover: none), (pointer: coarse) {
    .cursor { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { display: none; }
  }
</style>

<script>
  const ring = document.getElementById('cursor');
  const fine = window.matchMedia('(pointer: fine)').matches;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (ring && fine && !reduced) {
    document.documentElement.classList.add('has-cursor');

    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    let rx = mx;
    let ry = my;
    let shown = false;

    const interactive =
      'a, button, input, textarea, select, label, summary, [data-cursor], img, video, .media';

    window.addEventListener(
      'mousemove',
      (e) => {
        mx = e.clientX;
        my = e.clientY;
        if (!shown) {
          shown = true;
          ring.style.opacity = '1';
        }
      },
      { passive: true }
    );

    document.addEventListener('mouseleave', () => (ring.style.opacity = '0'));
    document.addEventListener('mouseenter', () => {
      if (shown) ring.style.opacity = '1';
    });

    window.addEventListener('mousedown', () => ring.classList.add('is-down'));
    window.addEventListener('mouseup', () => ring.classList.remove('is-down'));

    // Delegate hover state so dynamically-added nodes work too
    document.addEventListener('mouseover', (e) => {
      if ((e.target as Element)?.closest?.(interactive)) ring.classList.add('is-active');
    });
    document.addEventListener('mouseout', (e) => {
      if ((e.target as Element)?.closest?.(interactive)) ring.classList.remove('is-active');
    });

    // Eased trail — lerp toward the pointer each frame
    const tick = () => {
      rx += (mx - rx) * 0.18;
      ry += (my - ry) * 0.18;
      ring.style.transform = `translate(${rx}px, ${ry}px)`;
      requestAnimationFrame(tick);
    };
    tick();
  }
</script>
