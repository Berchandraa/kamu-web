---
/**
 * Footer — editorial close.
 * Sequence: newsletter as a serif invitation line → offset link
 * columns with the studio address → thin legal bar → a giant
 * KAMU wordmark deliberately cropped by the bottom edge of the
 * page (the brand sinking into the ground it stands on).
 * All content per brand PDF p.42–43.
 */
const year = new Date().getFullYear();
import SocialLinks from './SocialLinks.astro';

interface Props {
  logoVariant?: 'main' | 'by-kamu';
}

const { logoVariant = 'main' } = Astro.props;
const isByKamu = logoVariant === 'by-kamu';
---

<footer class="footer">
  <!-- ============ NEWSLETTER — the invitation line ============ -->
  <div class="grid-12 f-news">
    <p class="f-news-line">Slow interiors, in your inbox.</p>
    <form class="f-news-form" action="#" method="post">
      <input
        type="email"
        name="email"
        placeholder="jondoe@gmail.com"
        aria-label="Email address"
        required
      />
      <button type="submit" class="label">Sign up</button>
    </form>
  </div>

  <!-- ============ COLUMNS — offset on the 12-grid ============ -->
  <div class="grid-12 f-mid">
    <div class="f-brand">
      <a href="/" class="f-lockup" aria-label="KAMU Concepts — home">
        <span
          class={`f-logo ${isByKamu ? 'is-by-kamu' : 'is-main'}`}
          role="img"
          aria-label={isByKamu ? 'by KAMU' : 'KAMU Concepts'}
        ></span>
      </a>
      <address class="caption f-address">
        Jl. Dukuh Indah No.71, Umalas<br />
        Badung 80361, Bali, Indonesia
      </address>
      <p class="caption f-direct">
        <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a>
      </p>
    </div>

    <nav class="f-col" aria-label="Footer studio links">
      <span class="label f-key">Studio</span>
      <a href="/about/">About</a>
      <a href="/projects/">Projects</a>
      <a href="/careers/">Careers</a>
      <a href="/contact/">Contact</a>
    </nav>

    <nav class="f-col" aria-label="Footer shop links">
      <span class="label f-key">Shop</span>
      <a href="/shop/">All Pieces</a>
      <a href="/shop/">Dining</a>
      <a href="/shop/">Lounge</a>
      <a href="/shop/">Lighting</a>
    </nav>

    <nav class="f-col" aria-label="Footer social links">
      <span class="label f-key">
        <span class="duo"><span>Follow</span><span class="duo-sub">@kamuconcepts</span></span>
      </span>
      <SocialLinks />
    </nav>
  </div>

  <!-- ============ LEGAL BAR ============ -->
  <div class="grid-12 f-bar caption">
    <span class="duo">
      <span>&copy; {year}</span>
      <span class="duo-sub">KAMU Concepts</span>
    </span>
    <div class="f-legal">
      <a href="/terms/">Terms &amp; Conditions</a>
      <a href="/privacy/">Privacy Policy</a>
    </div>
    <button class="f-top label" id="f-top">Back to top</button>
  </div>

  <!-- ============ SUBTLE BRAND LINE — lighter than the previous giant mark ============ -->
  <div class="f-marquee" aria-hidden="true">
    <div class="f-marquee-track">
      <span>KAMU Concepts</span>
      <span>Slow Tropical Living</span>
      <span>Interiors Rooted in Craft</span>
      <span>KAMU Concepts</span>
      <span>Slow Tropical Living</span>
      <span>Interiors Rooted in Craft</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--c-bone);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    overflow: hidden;
    /* Legible "muted" tone on the dark footer — bone-based, not taupe,
       so supporting text and labels stay readable at small sizes. */
    --f-muted: color-mix(in srgb, var(--c-bone) 64%, transparent);
  }

  /* ================= NEWSLETTER ================= */
  .f-news {
    row-gap: var(--space-m);
    align-items: end;
    padding-bottom: var(--space-l);
  }

  .f-news-line {
    grid-column: 1 / 7;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.375rem, 2.2vw, 1.875rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--c-bone);
  }

  .f-news-form {
    grid-column: 8 / 13;
    display: flex;
    border-bottom: 1px solid color-mix(in srgb, var(--c-bone) 35%, transparent);
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .f-news-form:focus-within {
    border-color: var(--c-bone);
  }

  .f-news-form input {
    flex: 1;
    min-width: 0;
    background: none;
    border: none;
    outline: none;
    color: var(--c-bone);
    font-family: var(--font-serif);
    font-size: 1rem;
    padding: 0.75rem 0;
  }

  .f-news-form input::placeholder {
    color: color-mix(in srgb, var(--c-bone) 45%, transparent);
  }

  .f-news-form button {
    color: var(--c-bone);
    white-space: nowrap;
    padding-left: 0.75rem;
  }

  /* ================= COLUMNS ================= */
  .f-mid {
    row-gap: var(--space-l);
    padding-block: var(--space-l);
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 14%, transparent);
  }

  .f-brand {
    grid-column: 1 / 5;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-s);
  }

  /* Footer logo follows page context:
     main KAMU lockup for studio pages, byKAMU only for shop/collection. */
  .f-lockup {
    display: inline-flex;
  }

  .f-logo {
    display: block;
    background-color: var(--c-bone);
    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .f-logo.is-main {
    width: clamp(10rem, 16vw, 13rem);
    aspect-ratio: 648.07 / 144;
    -webkit-mask: url('/assets/asset-1.svg') no-repeat center left / contain;
    mask: url('/assets/asset-1.svg') no-repeat center left / contain;
  }

  .f-logo.is-by-kamu {
    width: clamp(8rem, 14vw, 10.5rem);
    aspect-ratio: 359.93 / 99.57;
    -webkit-mask: url('/assets/asset-2.svg') no-repeat center left / contain;
    mask: url('/assets/asset-2.svg') no-repeat center left / contain;
  }

  .f-lockup:hover .f-logo {
    background-color: color-mix(in srgb, var(--c-bone) 80%, transparent);
  }

  .f-address,
  .f-direct {
    font-style: normal;
    color: var(--f-muted);
    line-height: 1.7;
  }

  .f-direct a {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .f-direct a:hover {
    color: var(--c-bone);
  }

  .f-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .f-col:nth-of-type(1) {
    grid-column: 6 / 8;
  }

  .f-col:nth-of-type(2) {
    grid-column: 8 / 10;
  }

  .f-col:nth-of-type(3) {
    grid-column: 10 / 13;
  }

  .f-key {
    color: var(--f-muted);
    margin-bottom: 0.625rem;
  }

  .f-col > a {
    width: fit-content;
    position: relative;
  }

  .f-col > a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .f-col > a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ================= LEGAL BAR ================= */
  .f-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    padding-block: var(--space-s);
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 14%, transparent);
    color: var(--f-muted);
  }

  .f-legal {
    display: flex;
    gap: var(--space-s);
  }

  .f-legal a:hover,
  .f-top:hover {
    color: var(--c-bone);
  }

  .f-legal a,
  .f-top {
    transition: color var(--dur-fast) var(--ease-out);
  }

  .f-top {
    color: var(--f-muted);
  }

  /* ================= SUBTLE MARQUEE ================= */
  .f-marquee {
    margin-top: var(--space-m);
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 14%, transparent);
    overflow: hidden;
  }

  .f-marquee-track {
    width: max-content;
    display: flex;
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
    padding-block: clamp(1.25rem, 2.5vw, 2rem);
    white-space: nowrap;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.2vw, 2rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--c-bone) 52%, transparent);
    animation: f-marquee 28s linear infinite;
    user-select: none;
    pointer-events: none;
  }

  .f-marquee-track span::after {
    content: '+';
    margin-left: clamp(2rem, 4vw, 4rem);
    color: color-mix(in srgb, var(--c-bone) 28%, transparent);
  }

  @keyframes f-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .f-marquee-track {
      animation: none;
      transform: translateX(0);
    }
  }

  /* ================= RESPONSIVE ================= */
  @media (max-width: 56rem) {
    .f-news-line {
      grid-column: 1 / -1;
    }

    .f-news-form {
      grid-column: 1 / -1;
    }

    .f-brand {
      grid-column: 1 / -1;
    }

    .f-col:nth-of-type(1) {
      grid-column: 1 / 5;
    }

    .f-col:nth-of-type(2) {
      grid-column: 5 / 9;
    }

    .f-col:nth-of-type(3) {
      grid-column: 9 / 13;
    }

    .f-bar {
      flex-direction: column;
      align-items: flex-start;
    }

    .f-marquee-track {
      font-size: clamp(0.875rem, 5vw, 1.5rem);
    }
  }
</style>

<script>
  document.getElementById('f-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
