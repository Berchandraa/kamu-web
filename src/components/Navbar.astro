---
/**
 * Navbar — Yodezeen model.
 * Links spread edge to edge across the full bar width, wordmark
 * dead-centre, pill CTA at the far right. Thin weight, tracked out.
 * Transparent over the hero (inverted to bone when the page marks
 * a dark hero with [data-nav-invert]); condenses to a slim frosted
 * bone bar on scroll.
 */
const left = [
  { label: 'Projects', href: '/projects/' },
  { label: 'Shop', href: '/shop/' },
  { label: 'Contact', href: '/contact/' },
];

const right = [
  { label: 'About', href: '/about/' },
  { label: 'Careers', href: '/careers/' },
];

const all = [...left, ...right];
const current = Astro.url.pathname;
const isCurrent = (href: string) => current.startsWith(href.split('#')[0]);
const isProjectDetail = current.startsWith('/projects/') && current !== '/projects/';

// SHOP mega-menu (Sawdust model) — three calm columns
const shopMega = [
  {
    key: 'By Collection',
    links: [
      { label: 'Victoria Collection', href: '/shop/' },
      { label: 'Isabelle Collection', href: '/shop/' },
      { label: 'Agatha Collection', href: '/shop/' },
      { label: 'Kiki Collection', href: '/shop/' },
    ],
  },
  {
    key: 'By Area',
    links: [
      { label: 'Indoor', href: '/shop/' },
      { label: 'Outdoor', href: '/shop/' },
    ],
  },
  {
    key: 'By Type',
    links: [
      { label: 'Coffee Table', href: '/shop/' },
      { label: 'Side Table', href: '/shop/' },
      { label: 'Bar Chair', href: '/shop/' },
      { label: 'Artwork', href: '/shop/' },
      { label: 'Console', href: '/shop/' },
      { label: 'Bench', href: '/shop/' },
      { label: 'Wardrobe', href: '/shop/' },
    ],
  },
];
---


<header class="nav" id="nav" data-solid={isProjectDetail ? 'true' : undefined}>
  <div class="nav-inner">
    <nav class="nav-side nav-side-left" aria-label="Primary">
      {
        left.map((l) => (
          <a
            href={l.href}
            class="nav-link"
            data-mega={l.label === 'Shop' ? 'shop' : undefined}
            aria-haspopup={l.label === 'Shop' ? 'true' : undefined}
            aria-expanded={l.label === 'Shop' ? 'false' : undefined}
            aria-current={isCurrent(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a href="/" class="nav-brand" aria-label="KAMU Concepts — home">
      <span class="nav-logo" role="img" aria-label="KAMU Concepts"></span>
    </a>

    <div class="nav-side nav-side-right">
      {
        right.map((l) => (
          <a
            href={l.href}
            class="nav-link"
            aria-current={isCurrent(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <button class="nav-cart" type="button" aria-label="Open cart">
        <svg class="nav-cart-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 5h2l2.2 10.2a2 2 0 0 0 2 1.6h6.9a2 2 0 0 0 1.9-1.4L20.5 9H7.1" />
          <path d="M10 20h.01" />
          <path d="M17 20h.01" />
        </svg>
        <span class="nav-cart-n">0</span>
      </button>
    </div>

    <div class="nav-compact">
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-overlay"
      >
        <span class="nav-toggle-open">Menu</span>
        <span class="nav-toggle-close">Close</span>
      </button>
    </div>
  </div>

  <!-- ============ SHOP mega-menu ============ -->
  <div class="nav-mega" id="nav-mega" aria-hidden="true">
    <div class="nav-mega-inner">
      {
        shopMega.map((col) => (
          <div class="nav-mega-col">
            <span class="nav-mega-key label">{col.key}</span>
            {col.links.map((l) => (
              <a href={l.href} class="nav-mega-link">{l.label}</a>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <nav class="nav-overlay-links" aria-label="Menu">
    {
      all.map((l, i) => (
        <a href={l.href} class="nav-overlay-link h1" style={`--i: ${i}`}>
          {l.label}
        </a>
      ))
    }
  </nav>
  <div class="nav-overlay-foot caption">
    <span class="duo"><span>Bingin, Bali</span><span class="duo-sub">Indonesia</span></span>
    <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a>
  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 90;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    color: var(--ink);
    transition:
      height var(--dur-base) var(--ease-in-out),
      background-color var(--dur-base) var(--ease-in-out),
      color var(--dur-base) var(--ease-in-out);
  }

  /* Over a dark hero, before any scroll */
  .nav.is-inverted {
    color: var(--c-bone);
  }

  /* Scrolled: clean full-width spread on a SOLID bone bar, ink text —
     same layout as the static top nav, just grounded on opaque bone.
     (Solid, not translucent: a see-through bar let the hero's curved
     forms bleed up over the links and read as a stray arc.) */
  .nav.is-condensed {
    height: var(--nav-h-condensed);
    color: var(--ink);
    background: var(--bg);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 8%, transparent);
  }

  /* Edge-to-edge: gutter padding only, no max-width */
  .nav-inner {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-inline: var(--gutter);
  }

  /* ----- Link groups, spread across each half ----- */
  .nav-side {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-side-left {
    padding-right: clamp(3rem, 8vw, 9rem);
  }

  .nav-side-right {
    padding-left: clamp(3rem, 8vw, 9rem);
  }

  .nav-link {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--fs-label);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    position: relative;
    padding-block: 0.375rem;
    opacity: 0.92;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .nav-link:hover {
    opacity: 1;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .nav-link:hover::after,
  .nav-link[aria-current='page']::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ----- SHOP mega-menu (Sawdust model) ----- */
  .nav-mega {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    color: var(--ink);
    background: var(--bg);
    border-top: 1px solid color-mix(in srgb, var(--ink) 8%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    box-shadow: 0 30px 50px -34px rgba(32, 32, 32, 0.32);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      visibility 0s var(--dur-base);
  }

  html.mega-open .nav-mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      visibility 0s;
  }

  /* Opening the mega grounds the whole bar on solid bone */
  html.mega-open .nav {
    background: var(--bg);
    color: var(--ink);
  }

  .nav-mega-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    max-width: 60rem;
    padding: var(--space-l) var(--gutter) var(--space-xl);
  }

  .nav-mega-col {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
  }

  .nav-mega-key {
    color: var(--ink-soft);
    letter-spacing: 0.06em;
    margin-bottom: 0.55rem;
  }

  .nav-mega-link {
    position: relative;
    width: fit-content;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    color: var(--ink);
  }

  .nav-mega-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .nav-mega-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ----- Centre brand ----- */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: center;
  }

  /* Real KAMU CONCEPTS lockup (asset-1.svg), recoloured via mask so it
     follows the bar's currentColor — bone over the dark hero, ink on the
     scrolled bone bar — with no per-state filter hacks. */
  .nav-logo {
    display: block;
    height: 2.25rem;
    aspect-ratio: 648.07 / 144;
    width: auto;
    background-color: currentColor;
    -webkit-mask: url('/assets/asset-1.svg') no-repeat center / contain;
    mask: url('/assets/asset-1.svg') no-repeat center / contain;
    transition:
      height var(--dur-base) var(--ease-in-out),
      background-color var(--dur-base) var(--ease-in-out);
  }

  .nav.is-condensed .nav-logo {
    height: 1.75rem;
  }

  /* ----- Pill CTA ----- */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.7em 1.6em;
    border: 1px solid color-mix(in srgb, currentColor 55%, transparent);
    border-radius: 999px;
    white-space: nowrap;
    transition:
      background-color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .nav-cta-plus {
    font-size: 1.05em;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .nav-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--c-bone);
  }

  .nav-cta:hover .nav-cta-plus {
    transform: rotate(90deg);
  }

  /* ----- Cart Button ----- */
  .nav-cart {
    position: relative;
    display: grid;
    width: 2.75rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    border-radius: 50%;
    color: currentColor;
    background: transparent;
    transition:
      transform var(--dur-base) var(--ease-out),
      background-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
    margin-left: 1rem;
  }

  .nav-cart:hover {
    transform: translateY(-0.15rem);
    background: var(--ink);
    color: var(--c-bone);
    border-color: var(--ink);
  }

  .nav.is-inverted .nav-cart:hover {
    background: var(--c-bone);
    color: var(--ink);
    border-color: var(--c-bone);
  }

  .nav-cart-icon {
    width: 1.15rem;
    height: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nav-cart-n {
    position: absolute;
    top: -0.2rem;
    right: -0.2rem;
    display: grid;
    min-width: 1rem;
    height: 1rem;
    place-items: center;
    padding-inline: 0.2rem;
    border-radius: 999px;
    background: var(--accent);
    color: var(--c-bone);
    font-family: var(--font-serif);
    font-size: 0.65rem;
    line-height: 1;
  }

  /* ----- Compact menu on small screens ----- */
  .nav-compact {
    display: none;
    grid-column: 3;
    justify-self: end;
    align-items: center;
    gap: var(--space-s);
  }

  .nav-toggle {
    position: relative;
    z-index: 95;
    padding: 0.5rem 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--fs-label);
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .nav-toggle-close {
    display: none;
  }

  html.menu-open .nav-toggle-open {
    display: none;
  }

  html.menu-open .nav-toggle-close {
    display: inline;
  }

  /* ----- Overlay menu ----- */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 92;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--gutter);
    background: var(--ink);
    color: var(--c-bone);
    clip-path: inset(0 0 100% 0);
    visibility: hidden;
    transition:
      clip-path var(--dur-slow) var(--ease-in-out),
      visibility 0s var(--dur-slow);
  }

  html.menu-open .nav-overlay {
    clip-path: inset(0 0 0% 0);
    visibility: visible;
    transition:
      clip-path var(--dur-slow) var(--ease-in-out),
      visibility 0s;
  }

  .nav-overlay-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .nav-overlay-link {
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
    transition-delay: 0s;
  }

  html.menu-open .nav-overlay-link {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(0.35s + var(--i) * 0.06s);
  }

  .nav-overlay-link:hover {
    color: var(--accent-soft);
  }

  .nav-overlay-foot {
    position: absolute;
    bottom: var(--gutter);
    left: var(--gutter);
    right: var(--gutter);
    display: flex;
    justify-content: space-between;
    color: color-mix(in srgb, var(--c-bone) 64%, transparent);
  }

  html.menu-open .nav {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    color: var(--c-bone);
  }

  .nav-brand,
  .nav-toggle,
  .nav-compact {
    position: relative;
    z-index: 95;
  }

  @media (max-width: 64rem) {
    .nav-side {
      display: none;
    }

    .nav-mega {
      display: none;
    }

    .nav-compact {
      display: flex;
    }

    .nav-inner {
      grid-template-columns: 1fr auto 1fr;
    }

    .nav-brand {
      grid-column: 2;
    }

    .nav-logo {
      height: 1.75rem;
    }
  }
</style>

<script>
  import { cart, openCart } from '../scripts/cart';

  const nav = document.getElementById('nav');
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');
  const darkHero = document.querySelector('[data-nav-invert]');
  const solidNav = nav?.dataset.solid === 'true';

  const onScroll = () => {
    const condensed = solidNav || window.scrollY > 40;
    nav?.classList.toggle('is-condensed', condensed);
    nav?.classList.toggle('is-inverted', !!darkHero && !condensed && !solidNav);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = document.documentElement.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', String(open));
    overlay?.setAttribute('aria-hidden', String(!open));
    document.documentElement.classList.toggle('is-locked', open);
  });

  // ----- SHOP mega-menu -----
  const root = document.documentElement;
  const trigger = document.querySelector<HTMLAnchorElement>('[data-mega="shop"]');
  const mega = document.getElementById('nav-mega');
  const canHover = window.matchMedia('(hover: hover)').matches;

  if (trigger && mega) {
    let closeTimer: ReturnType<typeof setTimeout>;
    const isOpen = () => root.classList.contains('mega-open');

    const openMega = () => {
      clearTimeout(closeTimer);
      root.classList.add('mega-open');
      mega.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const closeMega = (immediate = false) => {
      clearTimeout(closeTimer);
      const done = () => {
        root.classList.remove('mega-open');
        mega.setAttribute('aria-hidden', 'true');
        trigger.setAttribute('aria-expanded', 'false');
      };
      if (immediate) done();
      else closeTimer = setTimeout(done, 140);
    };

    if (canHover) {
      [trigger, mega].forEach((el) => {
        el.addEventListener('mouseenter', openMega);
        el.addEventListener('mouseleave', () => closeMega());
      });
      trigger.addEventListener('focus', openMega);
    } else {
      // Touch: first tap opens, second tap follows the link to /shop/
      trigger.addEventListener('click', (e) => {
        if (!isOpen()) {
          e.preventDefault();
          openMega();
        }
      });
    }

    // Dismiss on Escape, outside click, or when the overlay menu opens
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) closeMega(true);
    });
    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      const t = e.target as Node;
      if (!mega.contains(t) && !trigger.contains(t)) closeMega(true);
    });
    toggle?.addEventListener('click', () => closeMega(true));
  }

  // ----- Cart Logic -----
  const cartBtn = document.querySelector<HTMLButtonElement>('.nav-cart');
  const cartCount = document.querySelector<HTMLElement>('.nav-cart-n');

  const syncCart = () => {
    if (cartCount) cartCount.textContent = String(cart.count());
  };

  cartBtn?.addEventListener('click', openCart);
  window.addEventListener('cart:updated', syncCart);
  syncCart();
</script>
