---
/**
 * Navbar — Yodezeen model.
 * Links spread edge to edge across the full bar width, wordmark
 * dead-centre, pill CTA at the far right. Thin weight, tracked out.
 * Transparent over the hero (inverted to bone when the page marks
 * a dark hero with [data-nav-invert]); condenses to a slim frosted
 * bone bar on scroll.
 */
const left = [
  { label: 'Projects', href: '/projects/' },
  { label: 'Shop', href: '/shop/' },
  { label: 'Contact', href: '/contact/' },
];

const right = [
  { label: 'About', href: '/about/' },
  { label: 'Careers', href: '/careers/' },
];

const all = [...left, ...right];
const current = Astro.url.pathname;
---

<header class="nav" id="nav">
  <div class="nav-inner">
    <nav class="nav-side nav-side-left" aria-label="Primary">
      {
        left.map((l) => (
          <a
            href={l.href}
            class="nav-link"
            aria-current={current.startsWith(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <a href="/" class="nav-brand" aria-label="KAMU Concepts — home">
      <img class="nav-logo" src="/assets/logo.png" alt="" width="1371" height="1459" />
      <span class="nav-wordmark">KAMU <em>Concepts</em></span>
    </a>

    <div class="nav-side nav-side-right">
      {
        right.map((l) => (
          <a
            href={l.href}
            class="nav-link"
            aria-current={current.startsWith(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contact/" class="nav-cta">
        Let&rsquo;s Talk <span class="nav-cta-plus" aria-hidden="true">+</span>
      </a>
    </div>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-overlay"
    >
      <span class="nav-toggle-open">Menu</span>
      <span class="nav-toggle-close">Close</span>
    </button>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <nav class="nav-overlay-links" aria-label="Menu">
    {
      all.map((l, i) => (
        <a href={l.href} class="nav-overlay-link h1" style={`--i: ${i}`}>
          {l.label}
        </a>
      ))
    }
  </nav>
  <div class="nav-overlay-foot caption">
    <span class="duo"><span>Bingin, Bali</span><span class="duo-sub">Indonesia</span></span>
    <a href="mailto:hello@kamuconcepts.com">hello@kamuconcepts.com</a>
  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 90;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    color: var(--ink);
    transition:
      height var(--dur-base) var(--ease-in-out),
      background-color var(--dur-base) var(--ease-in-out),
      color var(--dur-base) var(--ease-in-out);
  }

  /* Over a dark hero, before any scroll */
  .nav.is-inverted {
    color: var(--c-bone);
  }

  .nav.is-condensed {
    height: var(--nav-h-condensed);
    color: var(--ink);
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
  }

  /* Edge-to-edge: gutter padding only, no max-width */
  .nav-inner {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-inline: var(--gutter);
  }

  /* ----- Link groups, spread across each half ----- */
  .nav-side {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-side-left {
    padding-right: clamp(3rem, 8vw, 9rem);
  }

  .nav-side-right {
    padding-left: clamp(3rem, 8vw, 9rem);
  }

  .nav-link {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    position: relative;
    padding-block: 0.375rem;
    opacity: 0.92;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .nav-link:hover {
    opacity: 1;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .nav-link:hover::after,
  .nav-link[aria-current='page']::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ----- Centre brand ----- */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: center;
  }

  .nav-logo {
    height: 1.5rem;
    width: auto;
    transition:
      height var(--dur-base) var(--ease-in-out),
      filter var(--dur-base) var(--ease-in-out);
  }

  .nav.is-inverted .nav-logo {
    filter: invert(1);
  }

  .nav.is-condensed .nav-logo {
    height: 1.2rem;
  }

  .nav-wordmark {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-wordmark em {
    font-style: normal;
    font-weight: 300;
    letter-spacing: 0.3em;
  }

  /* ----- Pill CTA ----- */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.7em 1.6em;
    border: 1px solid color-mix(in srgb, currentColor 55%, transparent);
    border-radius: 999px;
    white-space: nowrap;
    transition:
      background-color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .nav-cta-plus {
    font-size: 1.05em;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .nav-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--c-bone);
  }

  .nav-cta:hover .nav-cta-plus {
    transform: rotate(90deg);
  }

  /* ----- Mobile toggle ----- */
  .nav-toggle {
    display: none;
    grid-column: 3;
    justify-self: end;
    position: relative;
    z-index: 95;
    padding: 0.5rem 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .nav-toggle-close {
    display: none;
  }

  html.menu-open .nav-toggle-open {
    display: none;
  }

  html.menu-open .nav-toggle-close {
    display: inline;
  }

  /* ----- Overlay menu ----- */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 92;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--gutter);
    background: var(--ink);
    color: var(--c-bone);
    clip-path: inset(0 0 100% 0);
    visibility: hidden;
    transition:
      clip-path var(--dur-slow) var(--ease-in-out),
      visibility 0s var(--dur-slow);
  }

  html.menu-open .nav-overlay {
    clip-path: inset(0 0 0% 0);
    visibility: visible;
    transition:
      clip-path var(--dur-slow) var(--ease-in-out),
      visibility 0s;
  }

  .nav-overlay-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .nav-overlay-link {
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
    transition-delay: 0s;
  }

  html.menu-open .nav-overlay-link {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(0.35s + var(--i) * 0.06s);
  }

  .nav-overlay-link:hover {
    color: var(--accent-soft);
  }

  .nav-overlay-foot {
    position: absolute;
    bottom: var(--gutter);
    left: var(--gutter);
    right: var(--gutter);
    display: flex;
    justify-content: space-between;
    color: var(--c-taupe);
  }

  html.menu-open .nav {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    color: var(--c-bone);
  }

  html.menu-open .nav-logo {
    filter: invert(1);
  }

  .nav-brand,
  .nav-toggle {
    position: relative;
    z-index: 95;
  }

  @media (max-width: 64rem) {
    .nav-side {
      display: none;
    }

    .nav-toggle {
      display: block;
    }

    .nav-inner {
      grid-template-columns: 1fr auto 1fr;
    }

    .nav-brand {
      grid-column: 2;
    }

    .nav-wordmark {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');
  const darkHero = document.querySelector('[data-nav-invert]');

  const onScroll = () => {
    const condensed = window.scrollY > 40;
    nav?.classList.toggle('is-condensed', condensed);
    nav?.classList.toggle('is-inverted', !!darkHero && !condensed);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = document.documentElement.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', String(open));
    overlay?.setAttribute('aria-hidden', String(!open));
    document.documentElement.classList.toggle('is-locked', open);
  });
</script>
